            <div class="subject-item">
                <img src="https://img.icons8.com/ios-filled/100/2563eb/globe.png" />
                <span>Địa</span>
            </div>

            <div class="subject-item">
                <img src="https://img.icons8.com/ios-filled/100/2563eb/law.png" />
                <span>GDCD</span>
            </div>
            <script>
                const track = document.querySelector(".slider-track");
                let items = document.querySelectorAll(".subject-item");

                items.forEach(item => {
                    const clone = item.cloneNode(true);
                    track.appendChild(clone);
                });

                let index = 0;

                function slide() {
                    index++;

                    const itemWidth = items[0].offsetWidth + 20;

                    track.style.transition = "transform 0.6s ease";
                    track.style.transform = `translateX(-${index * itemWidth}px)`;

                    if (index >= items.length) {
                        setTimeout(() => {
                            track.style.transition = "none";
                            track.style.transform = `translateX(0px)`;
                            index = 0;
                        }, 600);
                    }
                }

                let interval = setInterval(slide, 2000);

                track.addEventListener("mouseenter", () => clearInterval(interval));
                track.addEventListener("mouseleave", () => {
                    interval = setInterval(slide, 2000);
                });
            </script>
        </div>
