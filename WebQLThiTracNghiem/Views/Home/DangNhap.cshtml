@{
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
    ViewData["Title"] = "Đăng nhập";
}

<div class="login-wrapper">

    <div class="login-card shadow-lg">

        <div class="text-center mb-4">
            <h2 class="fw-bold">HỆ THỐNG THI TRẮC NGHIỆM</h2>
            <p class="text-muted mb-0">Đăng nhập để truy cập hệ thống</p>
        </div>

        <form method="post" asp-controller="Auth" asp-action="DangNhap">

            <div class="mb-3">
                <label class="form-label">Tên đăng nhập</label>

                <input type="text"
                       name="username"
                       class="form-control"
                       placeholder="Nhập tên đăng nhập"
                       required />
            </div>

            <div class="mb-3">
                <label class="form-label">Mật khẩu</label>

                <input type="password"
                       name="password"
                       class="form-control"
                       placeholder="Nhập mật khẩu"
                       required />
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.Error
                </div>
            }

            <div class="d-grid">
                <button type="submit" class="btn btn-primary btn-lg">
                    Đăng nhập
                </button>
            </div>

        </form>

        <div class="mt-3 text-center">

            <a href="javascript:void(0)"
               class="text-decoration-none text-primary fw-semibold">

                Quên mật khẩu?

            </a>

            <div class="alert alert-warning mt-3 text-center mb-2">

                Nếu bạn quên mật khẩu, vui lòng liên hệ quản trị hệ thống để được hỗ trợ.

            </div>

            <div class="text-center text-muted small">

                Email hỗ trợ:
                <strong>admin@qlthitracnghiem.edu.vn</strong>

                <br>

                Hotline:
                <strong>0900 000 000</strong>

            </div>

        </div>

    </div>

</div>