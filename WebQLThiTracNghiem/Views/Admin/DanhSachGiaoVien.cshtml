@model IEnumerable<WebQLThiTracNghiem.Models.GiaoVien>

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Quản lý giáo viên";
}
<div class="card-body">

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success">
            @TempData["success"]
        </div>
    }

    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["error"]
        </div>
    }
<div class="card shadow-sm">

    <div class="card-header d-flex justify-content-between align-items-center">

        <h5 class="mb-0">Quản lý giáo viên</h5>

        <a asp-action="XuatGiaoVienExcel"
           class="btn btn-success">
            Xuất Excel
        </a>

    </div>

        <form method="post" enctype="multipart/form-data" asp-action="LuuGiaoVien" id="formGV">
            <input type="hidden" name="id" id="editId" />

            <div class="row g-2 mb-4">

                <div class="col-md-4">
                    <input id="editTen"
                           name="hoten"
                           class="form-control"
                           placeholder="Họ tên giáo viên"
                           required />
                </div>

                <div class="col-md-4">
                    <input id="editUser"
                           name="username"
                           class="form-control"
                           placeholder="Tên đăng nhập"
                           required />
                </div>

                <!-- 🔥 FIX CHECKBOX -->
                <input type="hidden" name="laDaiDien" id="hiddenDaiDien" value="false" />

                <div class="col-md-2 d-flex align-items-center">
                    <div class="form-check">
                        <input type="checkbox"
                               id="laDaiDien"
                               class="form-check-input" />
                        <label class="form-check-label">Đại diện</label>
                    </div>
                </div>

                <div class="col-md-2">
                    <button type="submit"
                            class="btn btn-primary w-100"
                            id="btnSave">
                        Thêm
                    </button>
                </div>

                <div class="col-md-2">
                    <button type="button"
                            class="btn btn-secondary w-100"
                            onclick="resetForm()">
                        Mới
                    </button>
                </div>

            </div>
        </form>
        <!-- SEARCH -->

        <form method="get" class="row g-2 mb-3">

            <div class="col-md-4">

                <input type="text"
                       name="keyword"
                       value="@Context.Request.Query["keyword"]"
                       class="form-control"
                       placeholder="Tìm theo tên giáo viên" />

            </div>

            <div class="col-md-2">

                <button class="btn btn-secondary w-100">
                    Lọc
                </button>

            </div>

        </form>

        <!-- TABLE -->

      <table class="table table-bordered table-hover align-middle">

    <thead class="table-light">
        <tr>
            <th width="80">ID</th>
            <th>Họ tên</th>
            <th>Tên đăng nhập</th>
            <th width="120">Trạng thái</th>
            <th width="120">Đại diện</th>
            <th width="180">Thao tác</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var gv in Model)
        {
            <tr>

                <td>@gv.MaGiaoVien</td>

                <td>@gv.NguoiDung.HoSoCaNhan.HoTen</td>

                <td>@gv.NguoiDung.TenDangNhap</td>

                <!-- ✅ TRẠNG THÁI -->
                <td>
                    @if (gv.TrangThai)
                    {
                        <span class="badge bg-success">Hoạt động</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Khóa</span>
                    }
                </td>

                <!-- ✅ ĐẠI DIỆN -->
                <td>
                    @if (gv.LaDaiDien)
                   {
        <i class="bi bi-check-circle-fill text-success fs-5"></i>
    }
    else
    {
        <i class="bi bi-dash-circle text-muted"></i>
    }
                </td>

                <!-- ✅ THAO TÁC -->
                <td class="d-flex gap-1 align-items-center">

                    <!-- 👤 HỒ SƠ -->
                    <a asp-action="ChiTietNguoiDung"
                       asp-route-id="@gv.NguoiDung.MaNguoiDung"
                       class="btn btn-sm btn-info"
                       title="Hồ sơ">
                        <i class="bi bi-person"></i>
                    </a>

                            <!-- ✏️ SỬA -->
                            <button type="button"
                                    class="btn btn-sm btn-warning"
                                    title="Sửa"
                                    onclick="editGV(
                '@gv.MaGiaoVien',
                '@gv.NguoiDung.HoSoCaNhan.HoTen',
                '@gv.NguoiDung.TenDangNhap',
                @(gv.LaDaiDien.ToString().ToLower())
            )">
                                <i class="bi bi-pencil"></i>
                            </button>

                    <!-- 🗑️ XÓA -->
                    <a asp-action="XoaGiaoVien"
                       asp-route-id="@gv.MaGiaoVien"
                       class="btn btn-sm btn-danger"
                       title="Xóa"
                       onclick="return confirm('Bạn chắc chắn muốn xóa giáo viên?')">
                        <i class="bi bi-trash"></i>
                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>

    </div>

</div>
<div class="mt-4 d-flex justify-content-center">

    <ul class="pagination">

        <!-- << -->
        <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
            <a class="page-link"
               href="@Url.Action("DanhSachGiaoVien", new { page = ViewBag.CurrentPage - 1, keyword = ViewBag.Keyword })">
                «
            </a>
        </li>

        <!-- số -->
        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                <a class="page-link"
                   href="@Url.Action("DanhSachGiaoVien", new { page = i, keyword = ViewBag.Keyword })">
                    @i
                </a>
            </li>
        }

        <!-- >> -->
        <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
            <a class="page-link"
               href="@Url.Action("DanhSachGiaoVien", new { page = ViewBag.CurrentPage + 1, keyword = ViewBag.Keyword })">
                »
            </a>
        </li>

    </ul>

</div>

<script>
function editGV(id,ten,user,laDaiDien)
{
    document.getElementById("editId").value=id
    document.getElementById("editTen").value=ten
    document.getElementById("editUser").value=user
    document.getElementById("laDaiDien").checked = laDaiDien

    document.getElementById("btnSave").innerText="Cập nhật"
}

    function resetForm()
    {
        document.getElementById("editId").value=""
        document.getElementById("editTen").value=""
        document.getElementById("editUser").value=""
        document.getElementById("laDaiDien").checked = false
        document.getElementById("btnSave").innerText="Thêm"
    }

    setTimeout(function(){
        var alert=document.querySelector(".alert")
        if(alert){alert.style.display="none"}
    },3000)
        document.getElementById("formGV").addEventListener("submit", function () {
        var isChecked = document.getElementById("laDaiDien").checked;
        document.getElementById("hiddenDaiDien").value = isChecked;
    });
</script>
