@model IEnumerable<dynamic>

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Chi tiết đợt thi";

    var dotThi = ViewBag.DotThi;
}

<div class="gv-card shadow-sm">

    <!-- 🔥 HEADER -->
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h3 class="mb-1">Chi tiết đợt thi</h3>
            <p class="text-muted mb-0">Xem thông tin và kết quả thi của học sinh.</p>
        </div>

      <button class="btn btn-warning" onclick="showEdit()">
    ✏️ Sửa đợt thi
</button>
        <div class="d-flex gap-2">
            <a asp-action="XuatExcelChiTietDotThi"
               asp-route-id="@dotThi.MaDotThi"
               asp-route-lopId="@ViewBag.SelectedLop"
               class="btn btn-success">
                📥 Xuất Excel
            </a>

            <a asp-action="DanhSachDotThi" class="btn btn-outline-secondary">
                Quay lại
            </a>
        </div>
    </div>

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success">@TempData["success"]</div>
    }

    <!-- 🔥 THÔNG TIN -->
<div id="viewMode">
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <label class="fw-semibold">Mã đợt</label>
            <div>@dotThi.MaDotThi</div>
        </div>

        <div class="col-md-5">
            <label class="fw-semibold">Tên đợt thi</label>
            <div>@dotThi.TenDotThi</div>
        </div>

        <div class="col-md-2">
            <label class="fw-semibold">Môn học</label>
            <div>@dotThi.TenMonHoc</div>
        </div>

        <div class="col-md-2">
            <label class="fw-semibold">Đề thi</label>
            <div>@dotThi.TenDeThi</div>
        </div>

        <div class="col-md-3">
            <label class="fw-semibold">Bắt đầu</label>
            <div>@(((DateTime)dotThi.ThoiGianBatDau).ToString("dd/MM/yyyy HH:mm"))</div>
        </div>

        <div class="col-md-3">
            <label class="fw-semibold">Kết thúc</label>
            <div>@(((DateTime)dotThi.ThoiGianKetThuc).ToString("dd/MM/yyyy HH:mm"))</div>
        </div>
    </div>
      
</div>
<div id="editMode" style="display:none;" class="mb-4">
    <form asp-action="SuaDotThi" method="post">
        <input type="hidden" name="MaDotThi" value="@dotThi.MaDotThi" />

        <div class="row g-3">

            <div class="col-md-6">
                <label>Tên đợt thi</label>
                <input name="TenDotThi" value="@dotThi.TenDotThi" class="form-control" />
            </div>

            <div class="col-md-3">
                <label>Bắt đầu</label>
                <input type="datetime-local" name="ThoiGianBatDau"
                       value="@(((DateTime)dotThi.ThoiGianBatDau).ToString("yyyy-MM-ddTHH:mm"))"
                       class="form-control" />
            </div>

            <div class="col-md-3">
                <label>Kết thúc</label>
                <input type="datetime-local" name="ThoiGianKetThuc"
                       value="@(((DateTime)dotThi.ThoiGianKetThuc).ToString("yyyy-MM-ddTHH:mm"))"
                       class="form-control" />
            </div>

            <div class="col-md-3">
                <label>Số lần thi</label>
                <input name="SoLanThiToiDa" value="1" class="form-control" />
            </div>

        </div>

        <div class="mt-3">
            <button class="btn btn-success">💾 Lưu</button>
            <button type="button" class="btn btn-secondary" onclick="hideEdit()">Hủy</button>
        </div>
    </form>
</div>
    <!-- 🔥 FILTER -->
    <form method="get" class="d-flex gap-2 mb-3">
        <input type="hidden" name="id" value="@dotThi.MaDotThi" />

<select name="lop" class="form-select w-auto">
    <option value="">-- Tất cả lớp --</option>
            @foreach (var l in ViewBag.Lop)
            {
                <option value="@l.MaLop" selected="@(ViewBag.SelectedLop == l.MaLop)">
                    @l.TenLop
                </option>
            }
        </select>
        <!-- 🔥 LỌC TRẠNG THÁI -->
        <select name="trangThai" class="form-select w-auto">
            <option value="">-- Tất cả trạng thái --</option>
            <option value="dathi" selected="@(ViewBag.TrangThai == "dathi")">Đã nộp</option>
            <option value="chuathi" selected="@(ViewBag.TrangThai == "chuathi")">Chưa nộp</option>
        </select>
        <button class="btn btn-primary">Lọc</button>

        <a asp-action="ChiTietDotThi"
           asp-route-id="@dotThi.MaDotThi"
           class="btn btn-secondary">
            Reset
        </a>
    </form>

    <!-- 🔥 TABLE -->
    <h5 class="mb-3">Danh sách học sinh</h5>

    <div class="table-responsive">
        <table class="table table-bordered align-middle text-center">
            <thead class="table-light">
                <tr>
                    <th>Mã HS</th>
                    <th class="text-start">Họ tên</th>
                    <th>Lớp</th>
                    <th>Vào</th>
                    <th>Nộp</th>
                    <th>Điểm</th>
                    <th>Chi tiết</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.MaHocSinh</td>

                            <td class="text-start">@item.Ten</td>

                            <td>@item.Lop</td>

                            <td>
                                @(item.ThoiGianVao != null
                                                        ? item.ThoiGianVao.ToString("dd/MM/yyyy HH:mm")
                                                        : "-")
                    </td>

                            <td>
                        @if (item.ThoiGianNop == null)
                                {
                                    <span class="badge bg-secondary">Chưa nộp</span>
                                }
                                else
                                {
                                    @item.ThoiGianNop.ToString("dd/MM/yyyy HH:mm")
                                }
                            </td>

                            <td>
                                @if (item.ThoiGianNop == null)
                                {
                                    <span class="badge bg-secondary">-</span>
                                }
                                else if (item.Diem == 0)
                                {
                                    <span class="badge bg-danger">0</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">
                                        @Math.Round((double)item.Diem, 2)
                                    </span>
                                }
                            </td>

                            <td>
                                @if (item.Diem != null)
                                {
                                    <a asp-action="ChiTietBaiLam"
                                       asp-route-maHocSinh="@item.MaHocSinh"
                                       asp-route-maDotThi="@dotThi.MaDotThi"
                                       class="btn btn-sm btn-info">
                                        👁 Xem
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            Không có dữ liệu.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>
<script>
function showEdit() {
    document.getElementById("viewMode").style.display = "none";
    document.getElementById("editMode").style.display = "block";
}

function hideEdit() {
    document.getElementById("viewMode").style.display = "block";
    document.getElementById("editMode").style.display = "none";
}
</script>