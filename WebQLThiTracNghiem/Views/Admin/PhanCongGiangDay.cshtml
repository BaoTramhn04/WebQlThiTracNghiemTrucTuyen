@model IEnumerable<WebQLThiTracNghiem.Models.PhanCongGiangDay>

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Phân công giảng dạy";
}

<div class="card shadow-sm">

<div class="card-header">
<h5 class="mb-0">Phân công giảng dạy</h5>
</div>

<div class="card-body">

@if (TempData["success"] != null)
{
<div class="alert alert-success alert-dismissible fade show">

✔ @TempData["success"]

<button class="btn-close" data-bs-dismiss="alert"></button>

</div>
}

<!-- ================= THÊM PHÂN CÔNG ================= -->

<form method="post" asp-action="TaoPhanCongGiangDay">

<div class="row g-2 mb-4">

<div class="col-md-4">

<select name="magv" class="form-select" required>

<option value="">Chọn giáo viên</option>

@if (ViewBag.GiaoVien != null)
{
foreach (var gv in ViewBag.GiaoVien)
{
<option value="@gv.MaGiaoVien">
@gv.NguoiDung?.HoSoCaNhan?.HoTen
</option>
}
}

</select>

</div>

<div class="col-md-3">

<select name="malop" class="form-select" required>

<option value="">Chọn lớp</option>

@if (ViewBag.Lop != null)
{
foreach (var l in ViewBag.Lop)
{
<option value="@l.MaLop">
@l.TenLop
</option>
}
}

</select>

</div>

<div class="col-md-3">

<select name="mamon" class="form-select" required>

<option value="">Chọn môn</option>

@if (ViewBag.MonHoc != null)
{
foreach (var m in ViewBag.MonHoc)
{
<option value="@m.MaMonHoc">
@m.TenMonHoc
</option>
}
}

</select>

</div>

<div class="col-md-2">

<button class="btn btn-primary w-100">
Phân công
</button>

</div>

</div>

</form>


<!-- ================= BỘ LỌC ================= -->

<form method="get" class="row g-2 mb-3">

<div class="col-md-4">

<select name="gv" class="form-select">

<option value="">Lọc theo giáo viên</option>

@if (ViewBag.GiaoVien != null)
{
foreach (var gv in ViewBag.GiaoVien)
{
<option value="@gv.MaGiaoVien"
selected="@(Context.Request.Query["gv"] == gv.MaGiaoVien.ToString())">

@gv.NguoiDung?.HoSoCaNhan?.HoTen

</option>
}
}

</select>

</div>

<div class="col-md-3">

<select name="lop" class="form-select">

<option value="">Lọc theo lớp</option>

@if (ViewBag.Lop != null)
{
foreach (var l in ViewBag.Lop)
{
<option value="@l.MaLop"
selected="@(Context.Request.Query["lop"] == l.MaLop.ToString())">

@l.TenLop

</option>
}
}

</select>

</div>

<div class="col-md-3">

<select name="mon" class="form-select">

<option value="">Lọc theo môn</option>

@if (ViewBag.MonHoc != null)
{
foreach (var m in ViewBag.MonHoc)
{
<option value="@m.MaMonHoc"
selected="@(Context.Request.Query["mon"] == m.MaMonHoc.ToString())">

@m.TenMonHoc

</option>
}
}

</select>

</div>

<div class="col-md-2">

<button class="btn btn-secondary w-100">
Lọc
</button>

</div>

</form>


<!-- ================= BẢNG ================= -->

<table class="table table-bordered table-hover align-middle">

<thead class="table-light">

<tr>

<th>Giáo viên</th>
<th>Lớp</th>
<th>Môn học</th>
<th width="120">Thao tác</th>

</tr>

</thead>

<tbody>

@if (Model != null && Model.Any())
{
foreach (var pc in Model)
{
<tr>

<td>@pc.GiaoVien?.NguoiDung?.HoSoCaNhan?.HoTen</td>

<td>@pc.Lop?.TenLop</td>

<td>@pc.MonHoc?.TenMonHoc</td>

<td>

<a asp-action="XoaPhanCong"
asp-route-id="@pc.MaPhanCong"
class="btn btn-sm btn-danger"
onclick="return confirm('Bạn chắc chắn muốn xóa phân công này?')">

Xóa

</a>

</td>

</tr>
}
}
else
{
<tr>

<td colspan="4" class="text-center">
Chưa có phân công giảng dạy
</td>

</tr>
}

</tbody>

</table>

</div>

</div>

<script>

setTimeout(function(){

var alert=document.querySelector(".alert")

if(alert)
{
alert.style.display="none"
}

},3000)

</script>