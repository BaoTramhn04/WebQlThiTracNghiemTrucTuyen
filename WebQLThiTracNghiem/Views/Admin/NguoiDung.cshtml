@model List<WebQLThiTracNghiem.Models.NguoiDung>
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="card custom-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Danh sách người dùng</span>
         
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <form method="get" class="mb-3">
                <input type="text" name="keyword"
                       value="@Context.Request.Query["keyword"]"
                       placeholder="Tìm theo tên, mã hoặc username"
                       class="form-control"
                       style="width:300px; display:inline-block;" />

                <button type="submit" class="btn btn-primary">Tìm</button>

                <a asp-action="NguoiDung" class="btn btn-secondary">Tất cả</a>
            </form>
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Mã</th>
                        <th>Họ tên</th>
                        <th>Tên đăng nhập</th>
                        <th>Vai trò</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th width="180">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int stt = 1;
                    }

                   
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.MaNguoiDung</td>
                            <td>@item.HoSoCaNhan?.HoTen</td>
                            <td>@item.TenDangNhap</td>

                            <td>
                                @if (item.MaVaiTro == 1)
                                {
                                    <span class="badge bg-danger">Admin</span>
                                }
                                else if (item.MaVaiTro == 2)
                                {
                                    <span class="badge bg-primary">Giáo viên</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Học sinh</span>
                                }
                            </td>

                            <td>
                                @if (item.TrangThai)
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Đã khóa</span>
                                }
                            </td>

                            <td>
                                @item.NgayTao.ToString("dd/MM/yyyy")
                            </td>
                            <td>
                                <a asp-action="ResetMatKhau"
                                   asp-route-id="@item.MaNguoiDung"
                                   class="btn btn-sm btn-warning"
                                   onclick="return confirm('Reset mật khẩu về 1111?')">
                                    Reset
                                </a>

                                @if (item.TrangThai)
                                {
                                    <a asp-action="KhoaUser"
                                       asp-route-id="@item.MaNguoiDung"
                                       class="btn btn-sm btn-danger"
                                       onclick="return confirm('Khóa tài khoản?')">
                                        Khóa
                                    </a>
                                }
                                else
                                {
                                    <a asp-action="MoKhoaUser"
                                       asp-route-id="@item.MaNguoiDung"
                                       class="btn btn-sm btn-success"
                                       onclick="return confirm('Mở khóa tài khoản?')">
                                        Mở
                                    </a>
                                }
                            </td>
                        </tr>

                        stt++;
                    }
                    

                </tbody>

            </table>
        </div>
    </div>
</div>