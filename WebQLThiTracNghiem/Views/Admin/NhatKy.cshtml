@model List<WebQLThiTracNghiem.Models.NhatKyHeThong>

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Nhật ký hệ thống";
}

<div class="card custom-card">
    <div class="card-header fw-semibold">
        📜 Nhật ký hệ thống
    </div>

    <div class="card-body">

        <!-- FILTER -->
        <form method="get" class="row g-3 mb-3">

            <div class="col-md-3">
                <input type="date" name="fromDate" value="@ViewBag.FromDate" class="form-control" />
            </div>

            <div class="col-md-3">
                <input type="date" name="toDate" value="@ViewBag.ToDate" class="form-control" />
            </div>

            <div class="col-md-3">
                <select name="doiTuong" class="form-control">
                    <option value="">-- Tất cả đối tượng --</option>
                    <option value="Giáo viên">Giáo viên</option>
                    <option value="Học sinh">Học sinh</option>
                    <option value="Đợt thi">Đợt thi</option>
                </select>
            </div>

            <div class="col-md-3">
                <button class="btn btn-primary w-100">Lọc</button>
            </div>

        </form>

        <!-- TABLE -->
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Hành động</th>
                    <th>Đối tượng</th>
                    <th>Thời gian</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var log in Model)
                    {
                        <tr>
                            <td>
                                @if (log.HanhDong.Contains("Thêm"))
                                {
                                    <span class="badge bg-success">@log.HanhDong</span>
                                }
                                else if (log.HanhDong.Contains("Xóa"))
                                {
                                    <span class="badge bg-danger">@log.HanhDong</span>
                                }
                                else if (log.HanhDong.Contains("Khóa"))
                                {
                                    <span class="badge bg-warning text-dark">@log.HanhDong</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@log.HanhDong</span>
                                }
                            </td>

                            <td>@log.DoiTuongTacDong</td>

                            <td>@log.ThoiGianThucHien.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted">
                            Không có dữ liệu
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>