@model WebQLThiTracNghiem.Models.MonHoc

@{
    ViewData["Title"] = "Chi tiết môn học";
        Layout = "~/Views/Shared/_LayoutAdmin.cshtml";

}

<div class="container mt-4">

    <h2 class="mb-4">
        📘 Môn học: <span class="text-primary">@Model.TenMonHoc</span>
    </h2>

    <!--CARD THỐNG KÊ -->
    <div class="row mb-4">

        <div class="col-md-4">
            <div class="card shadow text-center">
                <div class="card-body">
                    <h6>🏫 Số lớp</h6>
                    <h3 class="text-primary">
                        @Model.PhanCongGiangDays.Select(x => x.MaLop).Distinct().Count()
                    </h3>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow text-center">
                <div class="card-body">
                    <h6>👨‍🏫 Giáo viên</h6>
                    <h3 class="text-success">
                        @Model.PhanCongGiangDays.Select(x => x.MaGiaoVien).Distinct().Count()
                    </h3>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow text-center">
                <div class="card-body">
                    <h6>📊 Phân công</h6>
                    <h3 class="text-danger">
                        @Model.PhanCongGiangDays.Count()
                    </h3>
                </div>
            </div>
        </div>

    </div>

    <!-- THANH TÌM KIẾM -->
    <div class="mb-3">
        <input type="text" id="searchTable" class="form-control"
               placeholder="🔍 Tìm giáo viên hoặc lớp..." onkeyup="filterTable()" />
    </div>

    <!--BẢNG PHÂN CÔNG -->
    <div class="card shadow">
        <div class="card-header fw-bold bg-dark text-white">
            📋 Danh sách phân công giảng dạy
        </div>

        <div class="card-body">

            <table id="dataTable" class="table table-bordered table-hover text-center align-middle">

                <thead class="table-secondary">
                    <tr>
                        <th>#</th>
                        <th>Tên giáo viên</th>
                        <th>Lớp</th>
                        <th>Hành động</th>
                    </tr>
                </thead>

                <tbody>
                    @{
                        int stt = 1;
                    }

                    @foreach (var pc in Model.PhanCongGiangDays)
                    {
                        <tr>
                            <td>@stt</td>

                            <td>
                                @pc.GiaoVien?.NguoiDung?.HoSoCaNhan?.HoTen
                            </td>

                            <td>
                                @pc.Lop?.TenLop
                            </td>

                            <td>
                                <a asp-action="XoaPhanCong"
                                   asp-route-id="@pc.MaPhanCong"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('Xóa phân công này?')">
                                    🗑
                                </a>
                            </td>
                        </tr>

                        stt++;
                    }
                </tbody>

            </table>

        </div>
    </div>

    <div class="mt-3">
        <a asp-action="MonHoc" class="btn btn-secondary">⬅ Quay lại</a>
    </div>

</div>

<!--SCRIPT TÌM KIẾM -->
<script>
    function filterTable() {
        var input = document.getElementById("searchTable");
        var filter = input.value.toLowerCase();
        var rows = document.querySelectorAll("#dataTable tbody tr");

        rows.forEach(row => {
            var text = row.innerText.toLowerCase();
            row.style.display = text.includes(filter) ? "" : "none";
        });
    }
</script>