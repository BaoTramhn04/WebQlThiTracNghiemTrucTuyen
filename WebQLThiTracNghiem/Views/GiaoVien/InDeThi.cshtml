@model IEnumerable<dynamic>

@{
    Layout = null;
    int i = 1;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>In đề thi</title>

    <style>
        body {
            font-family: "Times New Roman", serif;
            background: #f3f4f6;
            padding: 20px;
        }

        .exam-paper {
            width: 900px;
            margin: auto;
            background: #fff;
            padding: 50px 60px;
            border: 1px solid #ccc;
        }

        /* HEADER */
        .header {
            display: flex;
            justify-content: space-between;
        }

        .header-left {
            text-align: left;
            font-weight: bold;
        }

        .header-right {
            text-align: right;
            font-weight: bold;
        }

        .header-center {
            text-align: center;
            margin-top: 10px;
        }

            .header-center h2 {
                margin: 5px 0;
                text-transform: uppercase;
            }

        .sub-title {
            font-style: italic;
            font-size: 14px;
        }

        /* LINE */
        .line {
            border-top: 1px solid #000;
            width: 60%;
            margin: 5px auto;
        }

        /* MÃ ĐỀ */
        .ma-de {
            float: right;
            border: 1px solid #000;
            padding: 5px 12px;
            font-weight: bold;
            margin-top: 10px;
        }

        /* INFO */
        .info {
            margin-top: 20px;
        }

            .info div {
                margin-bottom: 8px;
            }

        hr {
            margin: 20px 0;
        }

        /* QUESTION */
        .question {
            margin-bottom: 18px;
        }

        /* ANSWER */
        .answers {
            margin-left: 25px;
        }

            .answers div {
                margin-bottom: 4px;
            }

        /* BUTTON */
        .btn-print {
            position: fixed;
            top: 15px;
            right: 20px;
            background: #2563eb;
            color: #fff;
            padding: 8px 14px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
        }

        @@media print {
            body {
                background: white;
            }

            .exam-paper {
                border: none;
                padding: 0;
            }

            .btn-print {
                display: none;
            }
        }
    </style>
</head>
<body>

    <button class="btn-print" onclick="window.print()">🖨 In đề</button>

    <div class="exam-paper">

        <!-- HEADER -->
        <div class="header">
            <div class="header-left">
                BỘ GIÁO DỤC VÀ ĐÀO TẠO<br />
                TRƯỜNG THPT NGÔ THÌ NHẬM
            </div>

            <div class="header-right">
                KỲ THI: @ViewBag.TenDe<br />
                Môn: @ViewBag.MonHoc<br />
                Thời gian: @ViewBag.ThoiGian phút
            </div>
        </div>

        <!-- CENTER -->
        <div class="header-center">
            <h2>ĐỀ THI</h2>
            <div class="sub-title">(Đề có @Model.Count() câu)</div>
            <div class="line"></div>
        </div>

        <!-- MÃ ĐỀ -->
        <div class="ma-de">
            Mã đề: @ViewBag.MaDe
        </div>

        <div style="clear:both"></div>

        <!-- INFO -->
        <div class="info">
            <div><b>Họ và tên:</b> ............................................................</div>
            <div><b>Lớp:</b> ............................</div>
        </div>

        <hr />

        <!-- QUESTIONS -->
        @foreach (var item in Model)
        {
            <div class="question">
                <b>Câu @i:</b> @Html.Raw(item.NoiDung)

                <div class="answers">
                    @{
                        char label = 'A';
                    }

                    @foreach (var da in item.DapAns)
                    {
                        if (ViewBag.ShowAnswer == true && da.LaDapAnDung)
                        {
                            <div><b>@label. @da.NoiDung</b></div>
                        }
                        else
                        {
                            <div>@label. @da.NoiDung</div>
                        }

                        label++;
                    }
                </div>
            </div>

            i++;
        }

    </div>

</body>
</html>