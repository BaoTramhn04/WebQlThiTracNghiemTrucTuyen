@model IEnumerable<dynamic>

@{
    Layout = "~/Views/Shared/_LayoutGiaoVien.cshtml";
    ViewData["Title"] = "Ngân hàng câu hỏi";
}

<div class="gv-card shadow-sm">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-1">Ngân hàng câu hỏi</h3>
            <p class="text-muted mb-0">Quản lý câu hỏi theo môn học, chuyên đề và mức độ.</p>
        </div>
        <a asp-action="TaoCauHoi" class="btn btn-primary">
            + Thêm câu hỏi
        </a>
    </div>

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success">@TempData["success"]</div>
    }
    @if (TempData["error"] is string errorMsg)
    {
        <div class="alert alert-danger">@errorMsg</div>
    }

    <form method="get" class="row g-2 mb-4">
        <div class="col-md-4">
            <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control" placeholder="Tìm theo nội dung câu hỏi..." />
        </div>

        <div class="col-md-2">
            <select name="khoi" class="form-select">
                <option value="">-- Khối --</option>
                <option value="10" selected="@(ViewBag.Khoi == 10)">Khối 10</option>
                <option value="11" selected="@(ViewBag.Khoi == 11)">Khối 11</option>
                <option value="12" selected="@(ViewBag.Khoi == 12)">Khối 12</option>
            </select>
        </div>
        <div class="col-md-2">
            <select name="monId" class="form-select">
                <option value="">-- Môn học --</option>
                @foreach (var mon in ViewBag.MonHoc)
                {
                    <option value="@mon.MaMonHoc" selected="@(ViewBag.MonId != null && ViewBag.MonId == mon.MaMonHoc)">
                        @mon.TenMonHoc
                    </option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <select name="chuyenDeId" class="form-select">
                <option value="">-- Chuyên đề --</option>
                @foreach (var cd in ViewBag.ChuyenDe)
                {
                    <option value="@cd.MaChuyenDe" selected="@(ViewBag.ChuyenDeId != null && ViewBag.ChuyenDeId == cd.MaChuyenDe)">
                        @cd.TenChuyenDe
                    </option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <select name="mucDo" class="form-select">
                <option value="">-- Mức độ --</option>
                <option value="1" selected="@(ViewBag.MucDo != null && ViewBag.MucDo == 1)">Nhận biết</option>
                <option value="2" selected="@(ViewBag.MucDo != null && ViewBag.MucDo == 2)">Thông hiểu</option>
                <option value="3" selected="@(ViewBag.MucDo != null && ViewBag.MucDo == 3)">Vận dụng</option>
            </select>
        </div>

        <div class="col-md-2">
            <select name="trangThai" class="form-select">
                <option value="">-- Trạng thái --</option>
                <option value="true" selected="@(ViewBag.TrangThai != null && ViewBag.TrangThai == true)">Đang dùng</option>
                <option value="false" selected="@(ViewBag.TrangThai != null && ViewBag.TrangThai == false)">Tạm ẩn</option>
            </select>
        </div>

        <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Lọc dữ liệu</button>
            <a asp-action="CauHoi" class="btn btn-outline-secondary">Đặt lại</a>
        </div>
    </form>
    <ul class="nav nav-tabs gv-tab mb-3">

       <li class="nav-item">
    <a class="nav-link @(ViewBag.Loai == null ? "active" : "")"
       href="@Url.Action("CauHoi", new {
           loai = "",
           khoi = ViewBag.Khoi,
           monId = ViewBag.MonId,
           chuyenDeId = ViewBag.ChuyenDeId,
           mucDo = ViewBag.MucDo,
           trangThai = ViewBag.TrangThai,
           keyword = ViewBag.Keyword
       })">
        📋 Tất cả
    </a>
</li>

<li class="nav-item">
    <a class="nav-link @(ViewBag.Loai == "mine" ? "active" : "")"
       href="@Url.Action("CauHoi", new {
           loai = "mine",
           khoi = ViewBag.Khoi,
           monId = ViewBag.MonId,
           chuyenDeId = ViewBag.ChuyenDeId,
           mucDo = ViewBag.MucDo,
           trangThai = ViewBag.TrangThai,
           keyword = ViewBag.Keyword
       })">
        👤 Câu của tôi
    </a>
</li>

<li class="nav-item">
    <a class="nav-link @(ViewBag.Loai == "other" ? "active" : "")"
       href="@Url.Action("CauHoi", new {
           loai = "other",
           khoi = ViewBag.Khoi,
           monId = ViewBag.MonId,
           chuyenDeId = ViewBag.ChuyenDeId,
           mucDo = ViewBag.MucDo,
           trangThai = ViewBag.TrangThai,
           keyword = ViewBag.Keyword
       })">
        👥 GV khác
    </a>
</li>

    </ul>



    <div class="table-responsive">
        <table class="table table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width:70px;">Mã</th>
                    <th>Nội dung câu hỏi</th>
                    <th style="width:140px;">Môn học</th>
                    <th style="width:160px;">Chuyên đề</th>
                    <th style="width:120px;">Khối</th>
                    <th style="width:120px;">Mức độ</th>
                    <th style="width:120px;">Trạng thái</th>
                    <th style="width:130px;">Ngày tạo</th>
                    <th style="width:120px;">Phân loại</th>
                    <th style="width:220px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.MaCauHoi</td>
                            <td>
                                <div style="max-width:300px; max-height:120px; overflow:hidden;">
                                    @Html.Raw(item.NoiDung)
                                </div>
                            </td>
                    <td>@item.TenMonHoc</td>
                    <td>@item.TenChuyenDe</td>
                            <td>
                                <span class="badge bg-info">Khối @item.Khoi</span>
                            </td>
                    <td>
                        @if (item.MucDo == 1)
                                {
                                    <span class="badge bg-success">Nhận biết</span>
                                }
                                else if (item.MucDo == 2)
                                {
                                    <span class="badge bg-warning text-dark">Thông hiểu</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Vận dụng</span>
                                }
                            </td>
                            <td>
                                @if (item.TrangThai)
                                {
                                    <span class="badge bg-primary">Đang dùng</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Tạm ẩn</span>
                                }
                            </td>
                            <td>@(((DateTime)item.NgayTao).ToString("dd/MM/yyyy"))</td>
                            <td>
                                @if (item.NguoiTao == ViewBag.MaGV)
                                {
                                    <span class="badge bg-success">Của tôi</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">GV khác</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex flex-wrap gap-1">
                                    <a asp-action="ChiTietCauHoi" asp-route-id="@item.MaCauHoi" class="btn btn-sm btn-outline-info">
                                        Chi tiết
                                    </a>

                                    @if (item.NguoiTao == ViewBag.MaGV)
                                    {
                                        <a asp-action="SuaCauHoi" asp-route-id="@item.MaCauHoi" class="btn btn-sm btn-outline-primary">
                                            Sửa
                                        </a>
                                    }

                                    @if (item.NguoiTao == ViewBag.MaGV)
                                    {
                                        <form asp-action="DoiTrangThaiCauHoi" asp-route-id="@item.MaCauHoi" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()

                                            @if (item.TrangThai)
                                            {
                                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                                        onclick="return confirm('Bạn có chắc muốn ẩn câu hỏi này không?')">
                                                    Ẩn
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-sm btn-outline-success"
                                                        onclick="return confirm('Bật lại câu hỏi này?')">
                                                    Bật lại
                                                </button>
                                            }
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            Chưa có câu hỏi nào phù hợp.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="d-flex justify-content-center mt-4">
            <ul class="pagination">

                <li class="page-item @(ViewBag.Page == 1 ? "disabled" : "")">
                    <a class="page-link"
                       href="?page=@(ViewBag.Page - 1)&keyword=@ViewBag.Keyword&monId=@ViewBag.MonId&chuyenDeId=@ViewBag.ChuyenDeId&khoi=@ViewBag.Khoi&loai=@ViewBag.Loai">
                        &lsaquo;
                    </a>
                </li>

                @{
                    int current = ViewBag.Page;
                    int total = ViewBag.TotalPage;

                    int start = Math.Max(1, current - 2);
                    int end = Math.Min(total, current + 2);
                }

                @if (start > 1)
                {
                    <li class="page-item">
                        <a class="page-link"
                           href="?page=1&keyword=@ViewBag.Keyword&monId=@ViewBag.MonId&chuyenDeId=@ViewBag.ChuyenDeId&khoi=@ViewBag.Khoi&loai=@ViewBag.Loai">
                            1
                        </a>
                    </li>

                    @if (start > 2)
                    {
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                    }
                }

                @for (int i = start; i <= end; i++)
                {
                    <li class="page-item @(i == current ? "active" : "")">
                        <a class="page-link"
                           href="?page=@i&keyword=@ViewBag.Keyword&monId=@ViewBag.MonId&chuyenDeId=@ViewBag.ChuyenDeId&khoi=@ViewBag.Khoi&loai=@ViewBag.Loai">
                            @i
                        </a>
                    </li>
                }

                @if (end < total)
                {
                    if (end < total - 1)
                    {
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                    }

                    <li class="page-item">
                        <a class="page-link"
                           href="?page=@total&keyword=@ViewBag.Keyword&monId=@ViewBag.MonId&chuyenDeId=@ViewBag.ChuyenDeId&khoi=@ViewBag.Khoi&loai=@ViewBag.Loai">
                            @total
                        </a>
                    </li>
                }

                <li class="page-item @(ViewBag.Page == ViewBag.TotalPage ? "disabled" : "")">
                    <a class="page-link"
                       href="?page=@(ViewBag.Page + 1)&keyword=@ViewBag.Keyword&monId=@ViewBag.MonId&chuyenDeId=@ViewBag.ChuyenDeId&khoi=@ViewBag.Khoi&loai=@ViewBag.Loai">
                        &rsaquo;
                    </a>
                </li>

            </ul>
        </div>
<style>
    .pagination .page-link {
        border-radius: 8px;
        margin: 0 4px;
        color: #333;
    }

    .pagination .page-item.active .page-link {
        background-color: #2563eb;
        border-color: #2563eb;
        color: #fff;
    }

    .pagination .page-item.disabled .page-link {
        opacity: 0.5;
    }
</style>