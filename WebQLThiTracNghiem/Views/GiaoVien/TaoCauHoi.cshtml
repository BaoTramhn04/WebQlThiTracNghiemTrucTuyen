@model WebQLThiTracNghiem.Models.CauHoi

@{
    Layout = "~/Views/Shared/_LayoutGiaoVien.cshtml";
    ViewData["Title"] = "Thêm câu hỏi";
}

<div class="gv-card shadow-sm">
    <div class="mb-3">
        <h3 class="mb-1">Thêm câu hỏi mới</h3>
        <p class="text-muted mb-0">Bạn có thể nhập nội dung, dán ảnh (Ctrl + V) hoặc thêm link ảnh.</p>
    </div>

    @Html.ValidationSummary(false, "", new { @class = "alert alert-danger" })

    <form asp-action="TaoCauHoi" method="post">
        @Html.AntiForgeryToken()

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Chuyên đề</label>
                <select asp-for="MaChuyenDe" class="form-select">
                    <option value="">-- Chọn chuyên đề --</option>
                    @foreach (var cd in ViewBag.ChuyenDe)
                    {
                        <option value="@cd.MaChuyenDe">@cd.TenChuyenDe</option>
                    }
                </select>
                <span asp-validation-for="MaChuyenDe" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label class="form-label">Mức độ</label>
                <select asp-for="MucDo" class="form-select">
                    <option value="1">Nhận biết</option>
                    <option value="2">Thông hiểu</option>
                    <option value="3">Vận dụng</option>
                </select>
            </div>

            <div class="col-md-3 d-flex align-items-end">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" checked disabled />
                    <label class="form-check-label">Mặc định đang dùng</label>
                </div>
            </div>

            <div class="col-12">
                <label class="form-label">Nội dung câu hỏi</label>

                <input type="hidden" name="NoiDung" id="noiDungHidden" />

                <div id="editor" contenteditable="true"
                     class="form-control"
                     style="min-height:120px;"></div>

                <span asp-validation-for="NoiDung" class="text-danger"></span>
            </div>
        </div>

        <hr class="my-4" />

        <h5 class="mb-3">Đáp án</h5>

        <div class="row g-3">
            @for (int i = 0; i < 4; i++)
            {
                var label = ((char)('A' + i)).ToString();

                <div class="col-12">
                    <label class="form-label">Đáp án @label</label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <input type="radio" name="dapAnDung" value="@i" @(i == 0 ? "checked" : "") />
                        </span>
                        <input type="text" name="dapAn" class="form-control" placeholder="Nhập đáp án @label" />
                    </div>
                </div>
            }
        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Lưu câu hỏi</button>
            <a asp-action="CauHoi" class="btn btn-outline-secondary">Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const editor = document.getElementById("editor");
        const hidden = document.getElementById("noiDungHidden");

        document.querySelector("form").addEventListener("submit", function (e) {

            let html = editor.innerHTML.trim();
            let text = editor.innerText.trim();

            if (!text) {
                e.preventDefault();
                alert("Vui lòng nhập nội dung câu hỏi!");
                return;
            }

            hidden.value = html;
        });

        editor.addEventListener("paste", function (e) {
            e.preventDefault();

            const items = (e.clipboardData || window.clipboardData).items;

            for (let i = 0; i < items.length; i++) {
                if (items[i].type.indexOf("image") !== -1) {
                    const file = items[i].getAsFile();
                    const reader = new FileReader();

                    reader.onload = function (event) {
                        const img = document.createElement("img");
                        img.src = event.target.result;
                        img.style.maxWidth = "100%";
                        editor.appendChild(img);
                    };

                    reader.readAsDataURL(file);
                }
            }
        });
    </script>
}