@model IEnumerable<dynamic>

@{
    Layout = "~/Views/Shared/_LayoutGiaoVien.cshtml";
    ViewData["Title"] = "Thêm câu hỏi vào đề";
    var deThi = ViewBag.DeThi;
}

<div class="gv-card shadow-sm">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-1">Thêm câu hỏi vào đề thi</h3>
            <p class="text-muted mb-0">Đề thi: <strong>@deThi.TenDeThi</strong></p>
        </div>
        <a asp-action="ChiTietDeThi" asp-route-id="@deThi.MaDeThi" class="btn btn-outline-secondary">Quay lại chi tiết đề</a>
    </div>

    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger">@TempData["error"]</div>
    }

    <form method="get" class="row g-2 mb-4">
        <input type="hidden" name="id" value="@deThi.MaDeThi" />

        <div class="col-md-5">
            <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control" placeholder="Tìm theo nội dung câu hỏi..." />
        </div>

        <div class="col-md-3">
            <select name="chuyenDeId" class="form-select">
                <option value="">-- Chuyên đề --</option>
                @foreach (var cd in ViewBag.ChuyenDe)
                {
                    <option value="@cd.MaChuyenDe" selected="@(ViewBag.ChuyenDeId != null && ViewBag.ChuyenDeId == cd.MaChuyenDe)">
                        @cd.TenChuyenDe
                    </option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <select name="mucDo" class="form-select">
                <option value="">-- Mức độ --</option>
                <option value="1" selected="@(ViewBag.MucDo != null && ViewBag.MucDo == 1)">Nhận biết</option>
                <option value="2" selected="@(ViewBag.MucDo != null && ViewBag.MucDo == 2)">Thông hiểu</option>
                <option value="3" selected="@(ViewBag.MucDo != null && ViewBag.MucDo == 3)">Vận dụng</option>
            </select>
        </div>

        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Lọc</button>
        </div>
    </form>

    <form asp-action="ThemCauHoiVaoDe" asp-route-id="@deThi.MaDeThi" method="post">
        @Html.AntiForgeryToken()

        <div class="table-responsive">
            <table class="table table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px;">Chọn</th>
                        <th style="width:70px;">Mã</th>
                        <th>Nội dung câu hỏi</th>
                        <th style="width:160px;">Chuyên đề</th>
                        <th style="width:120px;">Mức độ</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center">
                                    <input type="checkbox" name="cauHoiIds" value="@item.MaCauHoi" />
                                </td>
                                <td>@item.MaCauHoi</td>
                                <td>
                                    @(item.NoiDung != null && item.NoiDung.Length > 120
                                        ? item.NoiDung.Substring(0, 120) + "..."
                                        : item.NoiDung)
                                </td>
                                <td>@item.TenChuyenDe</td>
                                <td>
                                    @if (item.MucDo == 1)
                                    {
                                        <span class="badge bg-success">Nhận biết</span>
                                    }
                                    else if (item.MucDo == 2)
                                    {
                                        <span class="badge bg-warning text-dark">Thông hiểu</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Vận dụng</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                Không còn câu hỏi phù hợp để thêm vào đề.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Thêm các câu đã chọn</button>
            <a asp-action="ChiTietDeThi" asp-route-id="@deThi.MaDeThi" class="btn btn-outline-secondary">Hủy</a>
        </div>
    </form>
</div>