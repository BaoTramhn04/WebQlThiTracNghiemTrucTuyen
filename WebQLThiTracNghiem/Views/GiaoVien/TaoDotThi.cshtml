@model WebQLThiTracNghiem.Models.DotThi

@{
    Layout = "~/Views/Shared/_LayoutGiaoVien.cshtml";
    ViewData["Title"] = "Tạo đợt thi";
}

<div class="gv-card shadow-sm">
    <div class="mb-3">
        <h3 class="mb-1">Tạo đợt thi mới</h3>
        <p class="text-muted mb-0">
            Chọn khối, đề thi, đặt thời gian và tạo đợt thi cho học sinh tham gia.
        </p>
    </div>

    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger">@TempData["error"]</div>
    }

    @Html.ValidationSummary(false, "", new { @class = "alert alert-danger" })

    <form asp-action="TaoDotThi" method="post">
        @Html.AntiForgeryToken()   

        <div class="row g-3">

            <div class="col-md-4">
                <label class="form-label">Khối</label>
                <select class="form-select"
                        onchange="location.href='?khoi=' + this.value">

                    <option value="">-- Chọn khối --</option>
                    <option value="10" selected="@(ViewBag.Khoi == 10)">Khối 10</option>
                    <option value="11" selected="@(ViewBag.Khoi == 11)">Khối 11</option>
                    <option value="12" selected="@(ViewBag.Khoi == 12)">Khối 12</option>
                </select>
            </div>

            <div class="col-md-8">
                <label class="form-label">Tên đợt thi</label>
                <input asp-for="TenDotThi" class="form-control"
                       placeholder="Ví dụ: Thi thử cuối kỳ lớp 12A" required />
            </div>

            <div class="col-md-6">
                <label class="form-label">Đề thi</label>

                <select name="MaDeThi" id="maDeThi" class="form-select" required>
                    <option value="">-- Chọn đề thi --</option>

                    @if (ViewBag.DeThi != null)
                    {
                        foreach (var de in ViewBag.DeThi)
                        {
                            <option value="@de.MaDeThi"
                                    data-time="@de.ThoiGianLamBai"
                                    selected="@(Model?.MaDeThi == de.MaDeThi)">
                                @de.TenDeThi (Khối @de.Khoi) - @de.ThoiGianLamBai phút
                            </option>
                        }
                    }
                </select>
                <div class="col-md-6">
                    <label class="form-label">Thời gian làm bài</label>
                    <input type="number" id="thoiGian" class="form-control" readonly />
                </div>
            </div>

            <div class="col-md-6">
                <label class="form-label">Thời gian bắt đầu</label>
                <input asp-for="ThoiGianBatDau"
                       type="datetime-local"
                       class="form-control"
                       required />
            </div>

            <div class="col-md-6">
                <label class="form-label">Thời gian kết thúc</label>
                <input asp-for="ThoiGianKetThuc"
                       type="datetime-local"
                       class="form-control"
                       required />
            </div>

        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                Tạo đợt thi
            </button>

            <a asp-action="DotThi" class="btn btn-outline-secondary">
                Quay lại
            </a>
        </div>
    </form>
</div>
<script>
    const selectDe = document.getElementById("maDeThi");
    const inputTime = document.getElementById("thoiGian");

    selectDe.addEventListener("change", function () {
        const selected = this.options[this.selectedIndex];
        const time = selected.getAttribute("data-time");

        inputTime.value = time || "";
    });
</script>