@{
    Layout = "~/Views/Shared/_LayoutGiaoVien.cshtml";
    ViewData["Title"] = "Import câu hỏi";
}

<div class="gv-card shadow-sm">
    <h3 class="mb-3">📥 Import câu hỏi tự động</h3>
    <p class="text-muted">Hỗ trợ import từ Excel theo đúng định dạng bên dưới</p>

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success">@TempData["success"]</div>
    }

    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger">@TempData["error"]</div>
    }

    <div class="mb-4">
        <h5>📊 Import từ Excel</h5>

        <form asp-action="ImportExcel" method="post" enctype="multipart/form-data" class="d-flex gap-2">

            <select name="khoi" class="form-select" style="max-width:120px;" required>
                <option value="">Khối</option>
                <option value="10">10</option>
                <option value="11">11</option>
                <option value="12">12</option>
            </select>

            <input type="file" name="file" class="form-control" accept=".xlsx,.xls" required />

            <button class="btn btn-success">Import Excel</button>
        </form>

        <div class="mt-2 small text-muted">
            <b>Định dạng Excel:</b><br />
            Cột 1: Nội dung câu hỏi<br />
            Cột 2: Đáp án A<br />
            Cột 3: Đáp án B<br />
            Cột 4: Đáp án C (có thể bỏ trống)<br />
            Cột 5: Đáp án D (có thể bỏ trống)<br />
            Cột 6: Đáp án đúng (A/B/C/D)<br />
            Cột 7: Mức độ (1-3)<br />
            Cột 8: Tên chuyên đề (phải tồn tại trong hệ thống)<br />
            <span class="text-success">✔ Khối được chọn ở phía trên</span>
        </div>
    </div>
</div>