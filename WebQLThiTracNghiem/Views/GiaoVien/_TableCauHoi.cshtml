@model IEnumerable<dynamic>

<div class="table-responsive">
    <table class="table table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th style="width:70px;">Mã</th>
                <th>Nội dung câu hỏi</th>
                <th style="width:140px;">Môn học</th>
                <th style="width:160px;">Chuyên đề</th>
                <th style="width:120px;">Mức độ</th>
                <th style="width:120px;">Trạng thái</th>
                <th style="width:130px;">Ngày tạo</th>
                <th style="width:120px;">Phân loại</th>
                <th style="width:220px;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.MaCauHoi</td>
                        <td>
                            @(item.NoiDung != null && item.NoiDung.Length > 120
                                                ? item.NoiDung.Substring(0, 120) + "..."
                                                : item.NoiDung)
                </td>
                <td>@item.TenMonHoc</td>
                <td>@item.TenChuyenDe</td>

                        <td>
                    @if (item.MucDo == 1)
                            {
                                <span class="badge bg-success">Nhận biết</span>
                            }
                            else if (item.MucDo == 2)
                            {
                                <span class="badge bg-warning text-dark">Thông hiểu</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Vận dụng</span>
                            }
                        </td>

                        <td>
                            @if (item.TrangThai)
                            {
                                <span class="badge bg-primary">Đang dùng</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Tạm ẩn</span>
                            }
                        </td>

                        <td>@(((DateTime)item.NgayTao).ToString("dd/MM/yyyy"))</td>

                        <td>
                            @if (item.NguoiTao == ViewBag.MaGV)
                            {
                                <span class="badge bg-success">Của tôi</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">GV khác</span>
                            }
                        </td>

                        <td>
                            <div class="d-flex flex-wrap gap-1">
                                <a asp-action="ChiTietCauHoi" asp-route-id="@item.MaCauHoi"
                                   class="btn btn-sm btn-outline-info">
                                    Chi tiết
                                </a>

                                @if (item.NguoiTao == ViewBag.MaGV)
                                {
                                    <a asp-action="SuaCauHoi" asp-route-id="@item.MaCauHoi"
                                       class="btn btn-sm btn-outline-primary">
                                        Sửa
                                    </a>

                                    <form asp-action="DoiTrangThaiCauHoi"
                                          asp-route-id="@item.MaCauHoi"
                                          method="post" class="d-inline">

                                        @Html.AntiForgeryToken()

                                        @if (item.TrangThai)
                                        {
                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('Ẩn câu hỏi?')">
                                                Ẩn
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-success"
                                                    onclick="return confirm('Bật lại?')">
                                                Bật lại
                                            </button>
                                        }
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="9" class="text-center text-muted py-4">
                        Không có dữ liệu.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>