@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Tất cả hoạt động";
    Layout = "~/Views/Shared/_LayoutGiaoVien.cshtml";
}

<div class="gv-card">

    <!-- HEADER -->
    <div class="gv-card-header">
        <h4>📊 Tất cả hoạt động</h4>
    </div>

    <!-- FILTER -->
    <form method="get" class="filter-box">
        <div class="filter-group">
            <label>Từ ngày</label>
            <input type="date" name="tuNgay"
                   value="@ViewBag.TuNgay?.ToString("yyyy-MM-dd")" />
        </div>

        <div class="filter-group">
            <label>Đến ngày</label>
            <input type="date" name="denNgay"
                   value="@ViewBag.DenNgay?.ToString("yyyy-MM-dd")" />
        </div>

        <button type="submit" class="btn-filter">
            🔍 Lọc
        </button>
    </form>

    <!-- TABLE -->
    <div class="table-wrap">
        <table class="gv-table">
            <thead>
                <tr>
                    <th>Đợt thi</th>
                    <th>Môn học</th>
                    <th>Bắt đầu</th>
                    <th>Kết thúc</th>
                    <th>Trạng thái</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.TenDotThi</td>
                            <td>@item.TenMonHoc</td>
                            <td>@item.ThoiGianBatDau.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.ThoiGianKetThuc.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (item.TrangThaiText == "Đang mở")
                                {
                                    <span class="badge success">Đang mở</span>
                                }
                                else if (item.TrangThaiText == "Sắp diễn ra")
                                {
                                    <span class="badge warning">Sắp diễn ra</span>
                                }
                                else
                                {
                                    <span class="badge info">Đã kết thúc</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="empty">
                            Không có dữ liệu
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

   <div class="d-flex justify-content-center mt-4">
    <ul class="pagination">

        <!-- Prev -->
        <li class="page-item @(ViewBag.Page == 1 ? "disabled" : "")">
            <a class="page-link"
               href="@Url.Action("TatCaHoatDong", new {
                    page = ViewBag.Page - 1,
                    tuNgay = ViewBag.TuNgay,
                    denNgay = ViewBag.DenNgay
               })">
                ‹
            </a>
        </li>

        @{
            int current = ViewBag.Page;
            int total = ViewBag.TotalPage;

            int start = Math.Max(1, current - 2);
            int end = Math.Min(total, current + 2);
        }

        <!-- Trang đầu -->
        @if (start > 1)
        {
            <li class="page-item">
                <a class="page-link"
                   href="@Url.Action("TatCaHoatDong", new {
                        page = 1,
                        tuNgay = ViewBag.TuNgay,
                        denNgay = ViewBag.DenNgay
                   })">
                    1
                </a>
            </li>

            @if (start > 2)
            {
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
            }
        }

        <!-- Trang giữa -->
        @for (int i = start; i <= end; i++)
        {
            <li class="page-item @(i == current ? "active" : "")">
                <a class="page-link"
                   href="@Url.Action("TatCaHoatDong", new {
                        page = i,
                        tuNgay = ViewBag.TuNgay,
                        denNgay = ViewBag.DenNgay
                   })">
                    @i
                </a>
            </li>
        }

        <!-- Trang cuối -->
        @if (end < total)
        {
            if (end < total - 1)
            {
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
            }

            <li class="page-item">
                <a class="page-link"
                   href="@Url.Action("TatCaHoatDong", new {
                        page = total,
                        tuNgay = ViewBag.TuNgay,
                        denNgay = ViewBag.DenNgay
                   })">
                    @total
                </a>
            </li>
        }

        <!-- Next -->
        <li class="page-item @(ViewBag.Page == ViewBag.TotalPage ? "disabled" : "")">
            <a class="page-link"
               href="@Url.Action("TatCaHoatDong", new {
                    page = ViewBag.Page + 1,
                    tuNgay = ViewBag.TuNgay,
                    denNgay = ViewBag.DenNgay
               })">
                ›
            </a>
        </li>

    </ul>
</div>

</div>
<style>
    /* HEADER */
.gv-card-header {
    margin-bottom: 15px;
}

.gv-card-header h4 {
    font-weight: 600;
    margin: 0;
}

/* FILTER */
.filter-box {
    display: flex;
    gap: 15px;
    align-items: flex-end;
    margin-bottom: 20px;
    flex-wrap: wrap;
}

.filter-group {
    display: flex;
    flex-direction: column;
    font-size: 13px;
    color: #555;
}

.filter-group input {
    padding: 6px 10px;
    border-radius: 8px;
    border: 1px solid #ddd;
}

.btn-filter {
    padding: 7px 14px;
    border-radius: 8px;
    border: none;
    background: #2563eb;
    color: white;
    font-weight: 500;
}

/* TABLE */
.table-wrap {
    overflow-x: auto;
}

.gv-table {
    width: 100%;
    border-collapse: collapse;
}

.gv-table th {
    background: #f9fafb;
    padding: 10px;
    text-align: left;
    font-weight: 600;
    color: #374151;
}

.gv-table td {
    padding: 10px;
    border-bottom: 1px solid #eee;
}

.gv-table tr:hover {
    background: #f9fafb;
}

/* BADGE */
.badge {
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 13px;
}

.success {
    background: #ecfdf5;
    color: #065f46;
}

.warning {
    background: #fffbeb;
    color: #92400e;
}

.info {
    background: #eff6ff;
    color: #1e3a8a;
}

/* EMPTY */
.empty {
    text-align: center;
    color: #888;
    padding: 15px;
}

.pagination .page-link {
    border-radius: 8px;
    margin: 0 4px;
    color: #333;
}

.pagination .page-item.active .page-link {
    background-color: #2563eb;
    border-color: #2563eb;
    color: #fff;
}

.pagination .page-item.disabled .page-link {
    opacity: 0.5;
}
</style>