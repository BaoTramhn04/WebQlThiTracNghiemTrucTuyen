@model IEnumerable<dynamic>

@{
    Layout = "~/Views/Shared/_LayoutGiaoVien.cshtml";
    ViewData["Title"] = "Quản lý đề thi";
}

<div class="gv-card shadow-sm">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-1">Quản lý đề thi</h3>
            <p class="text-muted mb-0">Xem danh sách đề thi và quản lý nội dung từng đề.</p>
        </div>
        <a asp-action="TaoDeThi" class="btn btn-primary">+ Tạo đề thi</a>
    </div>

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success">@TempData["success"]</div>
    }

    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger">@TempData["error"]</div>
    }

    <form method="get" class="row g-2 mb-4">
        <div class="col-md-4">
            <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control" placeholder="Tìm theo tên đề thi..." />
        </div>

        <div class="col-md-3">
            <select name="monId" class="form-select">
                <option value="">-- Môn học --</option>
                @foreach (var mon in ViewBag.MonHoc)
                {
                    <option value="@mon.MaMonHoc" selected="@(ViewBag.MonId != null && ViewBag.MonId == mon.MaMonHoc)">
                        @mon.TenMonHoc
                    </option>
                }
            </select>
        </div>

        <div class="col-md-5 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Lọc dữ liệu</button>
            <a asp-action="DeThi" class="btn btn-outline-secondary">Đặt lại</a>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width:70px;">Mã</th>
                    <th>Tên đề thi</th>
                    <th style="width:140px;">Môn học</th>
                    <th style="width:120px;">Thời gian</th>
                    <th style="width:100px;">Số câu</th>
                    <th style="width:120px;">Trạng thái</th>
                    <th style="width:220px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.MaDeThi</td>
                            <td>@item.TenDeThi</td>
                            <td>@item.TenMonHoc</td>
                            <td>@item.ThoiGianLamBai phút</td>

                            <!-- 🔥 SỐ CÂU -->
                            <td>
                                <strong>@item.SoCau</strong>
                            </td>

                            <!-- 🔥 TRẠNG THÁI -->
                            <td>
                                @if (item.TrangThai)
                                {
                                    <span class="badge bg-success">Đang dùng</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Nháp</span>
                                }
                            </td>

                            <td>
                                <div class="d-flex gap-2">

                                    <!-- 🔥 NÚT CHÍNH -->
                                    <a asp-action="ThemCauHoiVaoDe"
                                       asp-route-id="@item.MaDeThi"
                                       class="btn btn-sm btn-primary">
                                        + Thêm câu
                                    </a>

                                    <!-- 🔥 MENU -->
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle"
                                                data-bs-toggle="dropdown">
                                            Tùy chọn
                                        </button>

                                        <ul class="dropdown-menu">

                                            <li>
                                                <a class="dropdown-item"
                                                   asp-action="ChiTietDeThi"
                                                   asp-route-id="@item.MaDeThi">
                                                    📄 Chi tiết
                                                </a>
                                            </li>

                                            <li>
                                                <a asp-action="SuaDeThi"
                                                   asp-route-id="@item.MaDeThi"
                                                   class="dropdown-item">
                                                    ✏️ Sửa đề
                                                </a>
                                            </li>

                                            <li><hr class="dropdown-divider"></li>

                                            @if (!item.DaSuDung)
                                            {
                                                <li>
                                                    <form asp-action="XoaDeThi" method="post">
                                                        <input type="hidden" name="id" value="@item.MaDeThi" />
                                                        <button class="dropdown-item text-danger"
                                                                onclick="return confirm('Xóa đề này?')">
                                                            🗑️ Xóa đề
                                                        </button>
                                                    </form>
                                                </li>
                                            }
                                            else
                                            {
                                                <li>
                                                    <span class="dropdown-item text-danger fw-bold">
                                                        🚫 Đề đã được sử dụng
                                                    </span>
                                                </li>

                                                <li>
                                                    <span class="dropdown-item text-muted">
                                                        Không thể sửa / xóa
                                                    </span>
                                                </li>

                                                <li><hr class="dropdown-divider"></li>

                                                <!-- 🔥 COPY ĐỀ -->
                                                <li>
                                                    <a class="dropdown-item text-primary"
                                                       asp-action="CopyDeThi"
                                                       asp-route-id="@item.MaDeThi">
                                                        📄 Sao chép đề
                                                    </a>
                                                </li>
                                            }

                                            <li><hr class="dropdown-divider"></li>

                                            <li>
                                                <a class="dropdown-item text-success"
                                                   asp-action="TaoDotThi"
                                                   asp-route-maDeThi="@item.MaDeThi">
                                                    📅 Tạo đợt thi
                                                </a>
                                            </li>

                                        </ul>
                                    </div>

                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            Chưa có đề thi nào.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
