@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Quản lý đề thi";
}

<div class="card custom-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Danh sách đề thi</span>
        <button class="btn btn-primary">+ Tạo đề thi</button>
    </div>
    <div class="card-body">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Mã đề</th>
                    <th>Tên đề thi</th>
                    <th>Môn học</th>
                    <th>Thời gian</th>
                    <th>Trạng thái</th>
                    <th width="180">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>1</td>
                    <td>Đề thi Toán 12 lần 1</td>
                    <td>Toán</td>
                    <td>15 phút</td>
                    <td><span class="badge bg-success">Đang dùng</span></td>
                    <td>
                        <button class="btn btn-sm btn-info">Chi tiết</button>
                        <button class="btn btn-sm btn-warning">Sửa</button>
                        <button class="btn btn-sm btn-danger">Xóa</button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>