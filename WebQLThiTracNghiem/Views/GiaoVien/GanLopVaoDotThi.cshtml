@{
    Layout = "~/Views/Shared/_LayoutGiaoVien.cshtml";
    ViewData["Title"] = "Gán lớp vào đợt thi";

    var dotThi = ViewBag.DotThi;
}

<div class="gv-card shadow-sm">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-1">Gán lớp vào đợt thi</h3>
            <p class="text-muted mb-0">Chọn lớp để thêm toàn bộ học sinh vào danh sách dự thi.</p>
        </div>
        <a asp-action="ChiTietDotThi" asp-route-id="@dotThi.MaDotThi" class="btn btn-outline-secondary">Quay lại chi tiết</a>
    </div>
    @{
        var dsLop = ViewBag.DanhSachLop as List<WebQLThiTracNghiem.Models.Lop>;
    }
    <div>Số lớp: @(dsLop?.Count ?? 0)</div>
    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger">@TempData["error"]</div>
    }

    <form asp-action="GanLopVaoDotThi" asp-route-id="@dotThi.MaDotThi" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="fw-semibold d-block mb-2">Tên đợt thi</label>
            <div>@dotThi.TenDotThi</div>
        </div>

        <div class="mb-3">
            <label class="fw-semibold d-block mb-3">Chọn lớp tham gia</label>

            <div class="row g-3">
                @{
                    var dsLop = ViewBag.DanhSachLop as List<WebQLThiTracNghiem.Models.Lop>;
                }

                @if (dsLop != null && dsLop.Any())
                {
                    foreach (var lop in dsLop)
                    {
                        <div class="col-md-4">
                            <label class="border rounded p-3 w-100 d-flex align-items-center gap-2">
                                <input type="checkbox" name="lopIds" value="@lop.MaLop" />
                                <span>@lop.TenLop</span>
                            </label>
                        </div>
                    }
                }
                else
                {
                    <div class="text-danger">Không có lớp nào</div>
                }
            </div>
        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Xác nhận gán lớp</button>
            <a asp-action="ChiTietDotThi" asp-route-id="@dotThi.MaDotThi" class="btn btn-outline-secondary">Hủy</a>
        </div>
    </form>
</div>