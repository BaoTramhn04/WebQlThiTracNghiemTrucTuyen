@model WebQLThiTracNghiem.Models.CauHoi

@{
    Layout = "~/Views/Shared/_LayoutGiaoVien.cshtml";
    ViewData["Title"] = "Sửa câu hỏi";

    var dapAns = ViewBag.DapAn as List<WebQLThiTracNghiem.Models.DapAn>;
}

<div class="gv-card shadow-sm">
    <div class="mb-3">
        <h3 class="mb-1">Sửa câu hỏi</h3>
        <p class="text-muted mb-0">Cập nhật nội dung, đáp án và trạng thái câu hỏi.</p>
    </div>

    @Html.ValidationSummary(false, "", new { @class = "alert alert-danger" })

    <form asp-action="SuaCauHoi" asp-route-id="@Model.MaCauHoi" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="MaCauHoi" />

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Chuyên đề</label>
                <select asp-for="MaChuyenDe" class="form-select">
                    <option value="">-- Chọn chuyên đề --</option>
                    @foreach (var cd in ViewBag.ChuyenDe)
                    {
                        <option value="@cd.MaChuyenDe">@cd.TenChuyenDe</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Mức độ</label>
                <select asp-for="MucDo" class="form-select">
                    <option value="1">Nhận biết</option>
                    <option value="2">Thông hiểu</option>
                    <option value="3">Vận dụng</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Trạng thái</label>
                <select asp-for="TrangThai" class="form-select">
                    <option value="true">Đang dùng</option>
                    <option value="false">Tạm ẩn</option>
                </select>
            </div>

            <div class="col-12">
                <label class="form-label">Nội dung câu hỏi</label>
                <textarea asp-for="NoiDung" class="form-control" rows="4"></textarea>
                <span asp-validation-for="NoiDung" class="text-danger"></span>
            </div>
        </div>

        <hr class="my-4" />

        <h5 class="mb-3">Cập nhật đáp án</h5>

        @if (dapAns != null && dapAns.Count >= 4)
        {
            var viTriDung = 0;
            for (int i = 0; i < dapAns.Count; i++)
            {
                if (dapAns[i].LaDapAnDung)
                {
                    viTriDung = i;
                    break;
                }
            }

            <div class="row g-3">
                @for (int i = 0; i < dapAns.Count; i++)
                {
                    var kyTu = i == 0 ? "A" : i == 1 ? "B" : i == 2 ? "C" : "D";

                    <div class="col-12">
                        <label class="form-label">Đáp án @kyTu</label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <input type="radio" name="dapAnDung" value="@i" @(viTriDung == i ? "checked" : null) />
                            </span>
                            <input type="text" name="dapAn" value="@dapAns[i].NoiDung" class="form-control" />
                        </div>
                    </div>
                }
            </div>
        }

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
            <a asp-action="CauHoi" class="btn btn-outline-secondary">Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}