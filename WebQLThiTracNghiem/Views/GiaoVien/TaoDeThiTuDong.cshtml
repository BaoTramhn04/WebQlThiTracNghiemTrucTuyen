@{
    Layout = "~/Views/Shared/_LayoutGiaoVien.cshtml";
    ViewData["Title"] = "Tạo đề tự động";
}

<div class="gv-card shadow-sm">

    <div class="mb-3">
        <h3 class="mb-1">⚡ Tạo đề thi tự động</h3>
        <p class="text-muted mb-0">
            Hệ thống sẽ tự động tạo đề (có thể chọn mức độ hoặc để random).
        </p>
    </div>

    @if (TempData["error"] != null)
    {
        <div id="alertBox" class="alert alert-danger">
            @TempData["error"]
        </div>
    }

    @if (TempData["success"] != null)
    {
        <div id="alertBox" class="alert alert-success">
            @TempData["success"]
        </div>
    }

    <form asp-action="TaoDeThiTuDong" method="post">
        @Html.AntiForgeryToken()

        <div class="row g-4">

            <div class="col-12">
                <h6 class="text-muted fw-semibold">Thông tin đề thi</h6>
            </div>

            <div class="col-md-6">
                <label class="form-label">Tên đề thi</label>
                <input name="tenDe" class="form-control"
                       placeholder="Để trống → hệ thống tự đặt tên" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Môn học</label>
                <select name="maMonHoc" id="monHoc" class="form-select" required>
                    @foreach (var mon in ViewBag.MonHoc)
                    {
                        <option value="@mon.MaMonHoc">@mon.TenMonHoc</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Khối</label>
                <select name="khoi" class="form-select" required>
                    <option value="10">Khối 10</option>
                    <option value="11">Khối 11</option>
                    <option value="12">Khối 12</option>
                </select>
            </div>

            <div class="col-12">
                <h6 class="text-muted fw-semibold">Cấu hình đề</h6>
            </div>

            <div class="col-md-4">
                <label class="form-label">Số câu hỏi</label>
                <input name="soCau" type="number" class="form-control" required />
            </div>

            <div class="col-md-4">
                <label class="form-label">Thời gian (phút)</label>
                <input name="thoiGian" type="number" class="form-control" required />
            </div>

            <div class="col-md-4">
                <label class="form-label">Mức độ đề</label>
                <select name="mucDoDe" class="form-select mucdo-select">
                    <option value="">-- Tự động (ngẫu nhiên) --</option>
                    <option value="de">Dễ</option>
                    <option value="tb">Trung bình</option>
                    <option value="kho">Khó</option>
                </select>
            </div>

            <div class="col-12">
                <h6 class="text-muted fw-semibold">Tùy chọn</h6>
            </div>

            <div class="col-md-4">
                <label class="form-label">Loại đề</label>
                <select name="loaiDe" id="loaiDe" class="form-select">
                    <option value="Rieng">Đề riêng</option>
                </select>
            </div>

        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="button" class="btn btn-success" onclick="submitForm()">
                ⚡ Tạo đề ngay
            </button>

            <button type="button" class="btn btn-info" onclick="previewDe()">
                👁 Xem trước đề
            </button>

            <a asp-action="DeThi" class="btn btn-outline-secondary">
                Quay lại
            </a>
        </div>
    </form>
</div>

<div class="modal fade" id="previewModal">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">⚡ Xem trước đề thi</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" id="previewContent"></div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">
                    ❌ Hủy
                </button>

                <button id="btnPreviewAgain" class="btn btn-warning" onclick="previewDe()">
                    🔁 Xem đề khác
                </button>

                <button class="btn btn-success" onclick="submitForm()">
                    ✅ Tạo đề chính thức
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>

        setTimeout(() => {
            const alert = document.getElementById("alertBox");
            if (alert) {
                alert.style.opacity = "0";
                setTimeout(() => alert.remove(), 500);
            }
        }, 3000);

        let laDaiDien = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    ViewBag.LaDaiDienTheoMon ?? new Dictionary<int, bool>()
            ));

    const monSelect = document.getElementById("monHoc");
    const loaiDe = document.getElementById("loaiDe");

        function updateLoaiDe() {
            const monId = monSelect.value;

            loaiDe.innerHTML = '<option value="Rieng">Đề riêng</option>';

            if (laDaiDien[monId] === true) {
                loaiDe.innerHTML += '<option value="Chung">Đề chung</option>';
            }
        }

        monSelect.addEventListener("change", updateLoaiDe);
        updateLoaiDe();

        let dePreview = [];
                let previewModalInstance = null; 
        let isLoadingPreview = false;    
               function previewDe() {

            let soCau = $("input[name='soCau']").val();
            let thoiGian = $("input[name='thoiGian']").val();
            let maMonHoc = $("#monHoc").val();
            let khoi = $("select[name='khoi']").val();
            let mucDoDe = $("select[name='mucDoDe']").val();

            if (!soCau) {
                alert("Nhập số câu trước nhé!");
                return;
            }

            if (!thoiGian || thoiGian <= 0) {
                alert("Nhập thời gian làm bài trước khi xem preview!");
                $("input[name='thoiGian']").focus();
                return;
            }

            if (isLoadingPreview) return;
            isLoadingPreview = true;

            $("#btnPreviewAgain").prop("disabled", true);

            $("#previewContent").html(`
                <div class="text-center p-4">
                    ⏳ Đang tạo đề thông minh...
                </div>
            `);

            $.get("/GiaoVien/PreviewDeThi", {
                soCau: soCau,
                maMonHoc: maMonHoc,
                khoi: khoi,
                mucDoDe: mucDoDe
            }, function (data) {

                dePreview = data.cauHoi.map(x => x.maCauHoi);

                let html = "";

                let tong = data.tong || 1;
                let dePercent = Math.round((data.de / tong) * 100);
                let trungPercent = Math.round((data.trung / tong) * 100);
                let khoPercent = Math.round((data.kho / tong) * 100);

                html += `
                    <div class="alert alert-warning">
                        ⚠️ Đề được tạo theo cấu hình đã chọn
                    </div>

                    <h6 class="fw-bold">📊 Tổng câu: ${data.tong}</h6>

                    <div class="mt-3">
                        <small>Dễ (${data.de})</small>
                        <div class="progress mb-2">
                            <div class="progress-bar bg-success" style="width:${dePercent}%">
                                ${dePercent}%
                            </div>
                        </div>

                        <small>Trung bình (${data.trung})</small>
                        <div class="progress mb-2">
                            <div class="progress-bar bg-warning text-dark" style="width:${trungPercent}%">
                                ${trungPercent}%
                            </div>
                        </div>

                        <small>Khó (${data.kho})</small>
                        <div class="progress mb-3">
                            <div class="progress-bar bg-danger" style="width:${khoPercent}%">
                                ${khoPercent}%
                            </div>
                        </div>
                    </div>

                    <hr/>
                `;

                data.cauHoi.forEach((cau, index) => {
                    html += `
                        <div class="mb-3 p-3 border rounded shadow-sm">
                            <b>${getBadge(cau.mucDo)} Câu ${index + 1}: ${cau.noiDung}</b>
                    `;

                    cau.dapAns.forEach((da, i) => {
                        html += `<div class="ms-3">${String.fromCharCode(65+i)}. ${da.noiDung}</div>`;
                    });

                    html += `</div>`;
                });

                $("#previewContent").html(html);

                if (!previewModalInstance) {
                    previewModalInstance = new bootstrap.Modal(document.getElementById('previewModal'));
                }

                previewModalInstance.show();

                isLoadingPreview = false;
                $("#btnPreviewAgain").prop("disabled", false);

            }).fail(function () {

                alert("Lỗi load preview!");

                isLoadingPreview = false;
                $("#btnPreviewAgain").prop("disabled", false);

            });
        }
        function getBadge(mucDo) {
            if (mucDo == 1) return '<span class="badge bg-success">Dễ</span>';
            if (mucDo == 2) return '<span class="badge bg-warning text-dark">Trung bình</span>';
            if (mucDo == 3) return '<span class="badge bg-danger">Khó</span>';
            return '';
        }

        // ================= TẠO ĐỀ =================
                  
                  function submitForm() {

            let thoiGian = $("input[name='thoiGian']").val();
            let soCau = $("input[name='soCau']").val();
            let maMonHoc = $("#monHoc").val();
            let khoi = $("select[name='khoi']").val();
            let mucDoDe = $("select[name='mucDoDe']").val();

            if (!soCau || soCau <= 0) {
                alert("Nhập số câu hỏi!");
                return;
            }

            if (!thoiGian || thoiGian <= 0) {
                alert("Nhập thời gian làm bài!");
                return;
            }

            // =========================================
            // CASE 1: ĐÃ PREVIEW → tạo đúng đề đó
            // =========================================
            if (dePreview && dePreview.length > 0) {

                $.ajax({
                    url: "/GiaoVien/TaoDeTuPreview",
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify({
                        dsCauHoi: dePreview,
                        thoiGian: parseInt(thoiGian)
                    }),
                    success: function (res) {

                        if (res && res.maDeThi) {
                            window.location.href = `/GiaoVien/ChiTietDeThi/${res.maDeThi}`;
                        } else {
                            alert("Tạo đề thành công nhưng không nhận được mã đề!");
                        }

                    },
                    error: function (err) {
                        console.error(err);
                        alert("Lỗi khi tạo đề từ preview!");
                    }
                });

            }
            // =========================================
            // CASE 2: CHƯA PREVIEW → tạo random
            // =========================================
            else {

                $("form").off("submit"); 
                $("form").submit();

            }
        }
    </script>
}
<style>
    .modal-body {
        max-height: 70vh;
        overflow-y: auto;
    }

    .shadow-sm:hover {
        transform: translateY(-2px);
        transition: 0.2s;
    }
</style>