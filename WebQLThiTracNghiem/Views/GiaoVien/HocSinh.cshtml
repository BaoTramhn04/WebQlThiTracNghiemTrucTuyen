@{
    Layout = "~/Views/Shared/_LayoutGiaoVien.cshtml";
    ViewData["Title"] = "Quản lý học sinh";
}

<div class="card custom-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Danh sách học sinh</span>
        <button class="btn btn-primary">+ Thêm học sinh</button>
    </div>
    <div class="card-body">
        <div class="mb-3 row">
            <div class="col-md-4">
                <input class="form-control" placeholder="Tìm theo họ tên hoặc số báo danh" />
            </div>
            <div class="col-md-3">
                <select class="form-select">
                    <option>Tất cả lớp</option>
                    <option>12A1</option>
                    <option>12A2</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-primary w-100">Tìm kiếm</button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Mã HS</th>
                        <th>Họ tên</th>
                        <th>Số báo danh</th>
                        <th>Lớp</th>
                        <th>Trạng thái</th>
                        <th width="180">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td>Trần Thị Học Sinh</td>
                        <td>HS001</td>
                        <td>12A1</td>
                        <td><span class="badge bg-success">Đang học</span></td>
                        <td>
                            <button class="btn btn-sm btn-warning">Sửa</button>
                            <button class="btn btn-sm btn-danger">Xóa</button>
                        </td>
                    </tr>
                    <tr>
                        <td>2</td>
                        <td>Nguyễn Văn C</td>
                        <td>HS002</td>
                        <td>12A1</td>
                        <td><span class="badge bg-success">Đang học</span></td>
                        <td>
                            <button class="btn btn-sm btn-warning">Sửa</button>
                            <button class="btn btn-sm btn-danger">Xóa</button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>