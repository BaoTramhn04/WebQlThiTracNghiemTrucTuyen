@model List<WebQLThiTracNghiem.Models.HocSinh>

@{
    Layout = "~/Views/Shared/_LayoutGiaoVien.cshtml";
    var danhSachLop = ViewBag.DanhSachLop as List<WebQLThiTracNghiem.Models.Lop>;
}

<div class="gv-card">

    <!-- LỌC THEO LỚP -->

 @{
var counts = ViewBag.SoLuongTheoLop as Dictionary<int, int>;}

<div style="margin-bottom:15px;">

    <a href="/GiaoVien/HocSinh"
       class="btn btn-outline-secondary btn-sm">
        Tất cả (@ViewBag.TongHocSinh)
    </a>

    @{
        int stt = 1;
    }

    @if (danhSachLop != null)
    {
        foreach (var lop in danhSachLop)
        {
          var soLuong = counts != null && counts.ContainsKey(lop.MaLop)
    ? counts[lop.MaLop]
    : 0;

                <a href="/GiaoVien/HocSinh?lopId=@lop.MaLop"
                   class="btn btn-outline-primary btn-sm"
                   style="margin-left:5px;">

                    @stt. @lop.KyHieuLop (@soLuong)

                </a>

                stt++;
            }
        }

    </div>

    <form method="get" class="gv-toolbar">

        <div class="gv-toolbar-left">

            <input type="text"
                   name="keyword"
                   class="form-control"
                   value="@Context.Request.Query["keyword"]"
                   placeholder="Tìm học sinh..."
                   style="min-width:240px;" />

            <select name="lopId"
                    class="form-select"
                    style="min-width:180px;">

                <option value="">Tất cả lớp</option>

                @if (danhSachLop != null)
                {
                    foreach (var lop in danhSachLop)
                    {
                        var selected = Context.Request.Query["lopId"] == lop.MaLop.ToString();

                        <option value="@lop.MaLop" selected="@selected">
                            @lop.KyHieuLop
                        </option>
                    }
                }

            </select>

            <button class="btn btn-secondary">
                Tìm
            </button>

        </div>

    </form>


    <!-- TABLE -->

    <div class="gv-table-wrap">

        <table class="gv-table">

            <thead>
                <tr>
                    <th>Mã học sinh</th>
                    <th>Họ tên</th>
                    <th>Lớp</th>
                    <th>Số báo danh</th>
                </tr>
            </thead>

            <tbody>

                @if (Model == null || Model.Count == 0)
                {
                    <tr>
                        <td colspan="5" style="text-align:center;">
                            Không có dữ liệu
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var hs in Model)
                    {
                        <tr>

                            <td>@hs.MaHocSinh</td>

                            <td>@hs.NguoiDung?.HoSoCaNhan?.HoTen</td>

                            <td>@hs.Lop?.KyHieuLop</td>

                            <td>@hs.SoBaoDanh</td>

                         
                        </tr>
                    }
                }

            </tbody>

        </table>

      @{
    int current = ViewBag.Page;
    int total = ViewBag.TotalPage;

    int start = Math.Max(1, current - 2);
    int end = Math.Min(total, current + 2);
}

<div class="pagination">

    @if (current > 1)
    {
        <a href="@Url.Action("HocSinh", new {
            page = current - 1,
            keyword = ViewBag.Keyword,
            lopId = ViewBag.LopId
        })" class="page-btn">‹</a>
    }

    @if (start > 1)
    {
        <a href="@Url.Action("HocSinh", new { page = 1 })" class="page-btn">1</a>
        <span class="dots">...</span>
    }

    @for (int i = start; i <= end; i++)
    {
        <a href="@Url.Action("HocSinh", new {
            page = i,
            keyword = ViewBag.Keyword,
            lopId = ViewBag.LopId
        })"
           class="page-btn @(i == current ? "active" : "")">
            @i
        </a>
    }

    @if (end < total)
    {
        <span class="dots">...</span>
        <a href="@Url.Action("HocSinh", new { page = total })" class="page-btn">@total</a>
    }

    @if (current < total)
    {
        <a href="@Url.Action("HocSinh", new {
            page = current + 1,
            keyword = ViewBag.Keyword,
            lopId = ViewBag.LopId
        })" class="page-btn">›</a>
    }

</div>

</div>
    </div>

</div>


<!-- MODAL CHUYỂN LỚP -->

<div class="modal fade" id="modalSuaHocSinh">

    <div class="modal-dialog">

        <div class="modal-content">

            <form method="post" asp-action="SuaHocSinh">

                <input type="hidden"
                       name="id"
                       id="editId">

                <div class="modal-header">

                    <h5 class="modal-title">
                        Chuyển lớp học sinh
                    </h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"></button>

                </div>

                <div class="modal-body">

                    <div class="mb-3">

                        <label>Chọn lớp</label>

                        <select name="MaLop"
                                id="editLop"
                                class="form-control">

                            @if (danhSachLop != null)
                            {
                                foreach (var lop in danhSachLop)
                                {
                                    <option value="@lop.MaLop">
                                        @lop.KyHieuLop
                                    </option>
                                }
                            }

                        </select>

                    </div>

                </div>

                <div class="modal-footer">

                    <button class="btn btn-primary">
                        Lưu
                    </button>

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Hủy
                    </button>

                </div>

            </form>

        </div>
    </div>

</div>


<script>

    function openEditModal(id, lop)
    {
        document.getElementById("editId").value = id;

        if(lop != null)
            document.getElementById("editLop").value = lop;

        var modal = new bootstrap.Modal(
            document.getElementById('modalSuaHocSinh'));

        modal.show();
    }

</script>
<style>
    .pagination {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: 20px;
}

.page-btn {
    padding: 6px 12px;
    border-radius: 8px;
    background: #f3f4f6;
    text-decoration: none;
    color: #333;
    border: 1px solid #ddd;
    font-size: 14px;
    transition: 0.2s;
}

.page-btn:hover {
    background: #e5e7eb;
}

.page-btn.active {
    background: #3b82f6;
    color: white;
    border-color: #3b82f6;
}

.dots {
    padding: 6px 8px;
    color: #999;
}
</style>