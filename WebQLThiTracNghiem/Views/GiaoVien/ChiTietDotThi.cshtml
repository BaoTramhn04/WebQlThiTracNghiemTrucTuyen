@{
    Layout = "~/Views/Shared/_LayoutGiaoVien.cshtml";
    ViewData["Title"] = "Chi tiết đợt thi";

    var dotThi = ViewBag.DotThi;
    var ds = ViewBag.DanhSachDuThi as IEnumerable<dynamic>;
}

<div class="gv-card shadow-sm">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h3 class="mb-1">Chi tiết đợt thi</h3>
            <p class="text-muted mb-0">Theo dõi thông tin đợt thi và danh sách học sinh dự thi.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="GanLopVaoDotThi" asp-route-id="@dotThi.MaDotThi" class="btn btn-primary">+ Gán lớp</a>
            <a asp-action="DotThi" class="btn btn-outline-secondary">Quay lại</a>
        </div>
    </div>

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success">@TempData["success"]</div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <label class="fw-semibold">Mã đợt thi</label>
            <div>@dotThi.MaDotThi</div>
        </div>
        <div class="col-md-5">
            <label class="fw-semibold">Tên đợt thi</label>
            <div>@dotThi.TenDotThi</div>
        </div>
        <div class="col-md-2">
            <label class="fw-semibold">Môn học</label>
            <div>@dotThi.TenMonHoc</div>
        </div>
        <div class="col-md-2">
            <label class="fw-semibold">Đề thi</label>
            <div>@dotThi.TenDeThi</div>
        </div>

        <div class="col-md-3">
            <label class="fw-semibold">Bắt đầu</label>
            <div>@(((DateTime)dotThi.ThoiGianBatDau).ToString("dd/MM/yyyy HH:mm"))</div>
        </div>
        <div class="col-md-3">
            <label class="fw-semibold">Kết thúc</label>
            <div>@(((DateTime)dotThi.ThoiGianKetThuc).ToString("dd/MM/yyyy HH:mm"))</div>
        </div>
    </div>

    <h5 class="mb-3">Danh sách học sinh dự thi</h5>

    <div class="table-responsive">
        <table class="table table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width:90px;">Mã HS</th>
                    <th style="width:120px;">SBD</th>
                    <th>Họ tên</th>
                    <th style="width:140px;">Lớp</th>
                    <th style="width:100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (ds != null && ds.Any())
                {
                    @foreach (var item in ds)
                    {
                        <tr>
                            <td>@item.MaHocSinh</td>
                            <td>@item.SoBaoDanh</td>
                            <td>@item.HoTen</td>
                            <td>@item.TenLop</td>
                            <td>
                                <form asp-action="XoaHocSinhKhoiDotThi" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="maDotThi" value="@dotThi.MaDotThi" />
                                    <input type="hidden" name="maHocSinh" value="@item.MaHocSinh" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Xóa học sinh này khỏi đợt thi?')">
                                        Xóa
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            Chưa có học sinh nào trong đợt thi này.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>