@{
    Layout = "~/Views/Shared/_LayoutGiaoVien.cshtml";
    ViewData["Title"] = "Chi tiết đợt thi";

    var dotThi = ViewBag.DotThi;
    var ds = ViewBag.DanhSachDuThi as IEnumerable<dynamic> ?? new List<dynamic>();
}

<div class="gv-card shadow-sm">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h3 class="mb-1">Chi tiết đợt thi</h3>
            <p class="text-muted mb-0">Theo dõi thông tin đợt thi và danh sách học sinh dự thi.</p>
        </div>
      <div class="d-flex gap-2">
    <button type="button" onclick="toggleEdit()" class="btn btn-warning">
        ✏️ Sửa
    </button>

    <a asp-action="GanLopVaoDotThi" asp-route-id="@dotThi.MaDotThi" class="btn btn-primary">
        + Gán lớp
    </a>
    <a asp-action="XuatExcelChiTietDotThi"
       asp-route-id="@dotThi.MaDotThi"
       class="btn btn-success">
        📥 Xuất Excel
    </a>
    <a asp-action="DotThi" class="btn btn-outline-secondary">
        Quay lại
    </a>
</div>
    </div>

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success">@TempData["success"]</div>
    }

    <!-- ===== THÔNG TIN ===== -->
    <div id="editForm" style="display:none;" class="mb-4">

    <form asp-action="SuaDotThi" method="post">
        <input type="hidden" name="MaDotThi" value="@dotThi.MaDotThi" />

        <div class="row g-3">

            <div class="col-md-4">
                <label>Tên đợt thi</label>
                <input name="TenDotThi" value="@dotThi.TenDotThi" class="form-control" />
            </div>

            <div class="col-md-3">
                <label>Bắt đầu</label>
                <input type="datetime-local"
                       name="ThoiGianBatDau"
                       value="@(((DateTime)dotThi.ThoiGianBatDau).ToString("yyyy-MM-ddTHH:mm"))"
                       class="form-control" />
            </div>

            <div class="col-md-3">
                <label>Kết thúc</label>
                <input type="datetime-local"
                       name="ThoiGianKetThuc"
                       value="@(((DateTime)dotThi.ThoiGianKetThuc).ToString("yyyy-MM-ddTHH:mm"))"
                       class="form-control" />
            </div>

        

        </div>

        <div class="mt-3">
            <button class="btn btn-success">💾 Lưu</button>
            <button type="button" onclick="toggleEdit()" class="btn btn-secondary">Huỷ</button>
        </div>

    </form>

</div>
    <div class="row g-3 mb-4">
        <div class="col-md-3"><b>Mã:</b> @dotThi.MaDotThi</div>
        <div class="col-md-5"><b>Tên:</b> @dotThi.TenDotThi</div>
        <div class="col-md-2"><b>Môn:</b> @dotThi.TenMonHoc</div>
        <div class="col-md-2"><b>Đề:</b> @dotThi.TenDeThi</div>

        <div class="col-md-3">
            <b>Bắt đầu:</b> @(((DateTime)dotThi.ThoiGianBatDau).ToString("dd/MM/yyyy HH:mm"))
        </div>
        <div class="col-md-3">
            <b>Kết thúc:</b> @(((DateTime)dotThi.ThoiGianKetThuc).ToString("dd/MM/yyyy HH:mm"))
        </div>
    </div>

    <h5>📊 Kết quả</h5>

    <form method="get" class="d-flex gap-2 mb-3">
        <input type="hidden" name="id" value="@dotThi.MaDotThi" />

        <select name="lopId" class="form-select w-auto">
            <option value="">-- Tất cả lớp --</option>
            @foreach (var l in ViewBag.Lop)
            {
                <option value="@l.MaLop" selected="@(ViewBag.LopId == l.MaLop)">
                    @l.TenLop
                </option>
            }
        </select>

        <select name="trangThai" class="form-select w-auto">
            <option value="">-- Trạng thái --</option>
            <option value="danop" selected="@(ViewBag.TrangThai == "danop")">Đã nộp</option>
            <option value="chuanop" selected="@(ViewBag.TrangThai == "chuanop")">Chưa nộp</option>
        </select>

        <button class="btn btn-primary">Lọc</button>
        <a href="?id=@dotThi.MaDotThi" class="btn btn-secondary">Reset</a>
    </form>

    <!-- ===== TABLE ===== -->
    <table class="table table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Mã học sinh</th>
                <th>Họ tên</th>
                <th>Lớp</th>
                <th>Vào</th>
                <th>Nộp</th>
                <th>Điểm</th>
                <th>Chi tiết</th>
            </tr>
        </thead>
        <tbody>
            @if (ds.Any())
            {
                foreach (var item in ds)
                {
                    <tr>
                        <td>@item.MaHocSinh</td>
                        <td>@item.HoTen</td>
                        <td>@item.TenLop</td>

                        <td>
                            @(item.ThoiDiemVao != null
                                                ? ((DateTime)item.ThoiDiemVao).ToString("dd/MM/yyyy HH:mm")
                                                : "-")
                </td>

                        <td>
                    @if (item.ThoiDiemNop != null)
                            {
                                @(((DateTime)item.ThoiDiemNop).ToString("dd/MM/yyyy HH:mm"))
                            }
                            else
                            {
                                <span class="text-danger">❌ Chưa nộp</span>
                            }
                        </td>

                        <td>
                            @if (item.Diem != null)
                            {
                                <span class="badge bg-success">@item.Diem</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">-</span>
                            }
                        </td>

                        <td>
                            @if (item.Diem != null)
                            {
                                <a asp-action="ChiTietBaiLam"
                                   asp-route-maHocSinh="@item.MaHocSinh"
                                   asp-route-maDotThi="@dotThi.MaDotThi"
                                   class="btn btn-sm btn-info">
                                    👁 Xem
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center">Không có dữ liệu</td>
                </tr>
            }
        </tbody>
    </table>
</div>
<script>
    function toggleEdit() {
        let f = document.getElementById("editForm");
        f.style.display = f.style.display === "none" ? "block" : "none";
    }
</script>