@model WebQLThiTracNghiem.Models.ViewModels.DoiMatKhauViewModel

@{
    Layout = null;
    ViewData["Title"] = "Đổi mật khẩu";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Đổi mật khẩu</title>

    <style>
        body {
            margin: 0;
            font-family: "Segoe UI";
            background: #f8fafc; /* 🔥 nền trắng nhẹ */
            min-height: 100vh;
        }

        /* CENTER */
        .wrapper-center {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* CARD */
        .change-pass-card {
            width: 100%;
            max-width: 420px;
            padding: 28px;
            border-radius: 18px;
            background: #ffffff;
            /* 🔥 VIỀN XANH */
            border: 2px solid rgba(59, 130, 246, 0.4);
            /* 🔥 ĐỔ BÓNG */
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
            animation: fadeInUp 0.6s ease;
            transition: 0.3s;
        }

            .change-pass-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 15px 35px rgba(59, 130, 246, 0.2);
            }

        /* INPUT */
        .custom-input {
            width: 100%;
            border-radius: 10px;
            padding: 10px 14px;
            border: 1px solid #cbd5f5;
            transition: all 0.25s ease;
        }

            .custom-input:focus {
                border-color: #3b82f6;
                box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
                transform: scale(1.02);
                outline: none;
            }

        /* BUTTON */
        .btn-main {
            background: linear-gradient(135deg, #3b82f6, #60a5fa);
            border: none;
            color: white;
            font-weight: 600;
            border-radius: 10px;
            padding: 10px;
            transition: all 0.2s ease;
            width: 100%;
        }

            .btn-main:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(59, 130, 246, 0.3);
            }

            .btn-main:active {
                transform: scale(0.96);
            }

        .btn-back {
            width: 100%;
            border-radius: 10px;
            padding: 10px;
            text-align: center;
            text-decoration: none;
            border: 1px solid #cbd5f5;
            color: #334155;
            transition: 0.2s;
        }

            .btn-back:hover {
                background: #f1f5f9;
            }

        /* ANIMATION */
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px) scale(0.95);
            }

            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }
    </style>
</head>

<body>

    <div class="wrapper-center">
        <div class="change-pass-card">

            <div style="text-align:center; margin-bottom:15px;">
                <h2>Đổi mật khẩu</h2>
                <p style="color:#64748b; font-size:14px;">
                    Cập nhật mật khẩu để bảo mật tài khoản
                </p>
            </div>

            @if (ViewBag.Loi != null)
            {
                <div style="color:red; text-align:center; margin-bottom:10px;">
                    @ViewBag.Loi
                </div>
            }

            @if (ViewBag.ThanhCong != null)
            {
                <div style="color:green; text-align:center; margin-bottom:10px;">
                    @ViewBag.ThanhCong
                </div>
            }

            <form asp-action="DoiMatKhau" method="post">

                <div style="margin-bottom:12px;">
                    <label>Mật khẩu hiện tại</label>
                    <input asp-for="MatKhauHienTai" type="password" class="custom-input" />
                </div>

                <div style="margin-bottom:12px;">
                    <label>Mật khẩu mới</label>
                    <input asp-for="MatKhauMoi" type="password" class="custom-input" />
                </div>

                <div style="margin-bottom:16px;">
                    <label>Xác nhận mật khẩu mới</label>
                    <input asp-for="XacNhanMatKhauMoi" type="password" class="custom-input" />
                </div>

                <div style="display:flex; gap:10px;">
                    <button type="submit" class="btn-main">
                        Cập nhật
                    </button>

                    <a href="/HocSinh/BatDauThi" class="btn-back">
                        Quay lại
                    </a>
                </div>

            </form>
        </div>
    </div>

</body>
</html>