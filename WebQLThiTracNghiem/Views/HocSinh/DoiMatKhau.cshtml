@model WebQLThiTracNghiem.Models.ViewModels.DoiMatKhauViewModel

@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="container py-4">
    <partial name="_HocSinhHeader" />

    <div class="student-form-card">
        <div class="student-form-card-header">
            <h2 class="student-form-card-title">Đổi mật khẩu tài khoản</h2>
        </div>

        <div class="student-form-card-body">
            @if (ViewBag.Loi != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.Loi
                </div>
            }

            @if (ViewBag.ThanhCong != null)
            {
                <div class="alert alert-success">
                    @ViewBag.ThanhCong
                </div>
            }

            <form asp-action="DoiMatKhau" method="post">
                <div class="mb-3">
                    <label asp-for="MatKhauHienTai" class="form-label fw-semibold">Mật khẩu hiện tại</label>
                    <input asp-for="MatKhauHienTai" class="form-control form-control-lg" />
                    <span asp-validation-for="MatKhauHienTai" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="MatKhauMoi" class="form-label fw-semibold">Mật khẩu mới</label>
                    <input asp-for="MatKhauMoi" class="form-control form-control-lg" />
                    <span asp-validation-for="MatKhauMoi" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="XacNhanMatKhauMoi" class="form-label fw-semibold">Xác nhận mật khẩu mới</label>
                    <input asp-for="XacNhanMatKhauMoi" class="form-control form-control-lg" />
                    <span asp-validation-for="XacNhanMatKhauMoi" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <button type="submit" class="btn btn-primary px-4">
                        Cập nhật mật khẩu
                    </button>

                    <a asp-controller="HocSinh"
                       asp-action="DanhSachDotThi"
                       class="btn btn-outline-secondary px-4">
                        Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}