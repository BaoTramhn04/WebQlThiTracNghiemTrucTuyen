@model List<WebQLThiTracNghiem.Models.ViewModels.DanhSachDotThiHocSinhViewModel>

@{
    ViewData["Title"] = "Danh sách đợt thi";

}

<div class="container py-4">
    <partial name="_HocSinhHeader" />

    <div class="student-page-card">
        <div class="student-page-card-header">
            <h2 class="student-page-title">
                Danh sách đợt thi được phân công
            </h2>

            <div class="student-page-actions">
                <a asp-controller="HocSinh"
                   asp-action="DoiMatKhau"
                   class="student-btn-soft student-btn-primary-soft">
                    Đổi mật khẩu
                </a>

                <a asp-controller="Home"
                   asp-action="DangNhap"
                   class="student-btn-soft student-btn-danger-soft">
                    Đăng xuất
                </a>
            </div>
        </div>

        <div class="student-page-card-body">
            @if (TempData["Loi"] != null)
            {
                <div class="alert alert-danger mb-3">
                    @TempData["Loi"]
                </div>
            }

            @if (Model == null || !Model.Any())
            {
                <div class="student-empty-box">
                    Hiện tại bạn chưa có đợt thi nào được phân công.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover student-table">
                        <thead class="table-light">
                            <tr>
                                <th>Mã đợt thi</th>
                                <th>Tên đợt thi</th>
                                <th>Đề thi</th>
                                <th>Môn thi</th>
                                <th>Bắt đầu</th>
                                <th>Kết thúc</th>
                                <th>Thời lượng</th>
                                <th>Số lần thi</th>
                                <th>Cho phép thi</th>
                                <th>Trạng thái</th>
                                <th>Ghi chú</th>
                                <th>Thi</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>#@item.MaDotThi</strong>
                                    </td>

                                    <td>@item.TenDotThi</td>

                                    <td>@item.TenDeThi</td>

                                    <td>@item.MonThi</td>

                                    <td>@item.ThoiGianBatDau.ToString("dd/MM/yyyy HH:mm")</td>

                                    <td>@item.ThoiGianKetThuc.ToString("dd/MM/yyyy HH:mm")</td>

                                    <td>@item.ThoiGianLamBai phút</td>

                                    <td>@item.SoLanThiToiDa</td>

                                    <td>
                                        @if (item.DuocPhepThi)
                                        {
                                            <span class="student-chip-info">
                                                Được phép
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="student-chip-danger">
                                                Không được phép
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        @if (item.TrangThaiHienThi == "Đang mở")
                                        {
                                            <span class="student-chip-success">
                                                @item.TrangThaiHienThi
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="student-chip-danger">
                                                @item.TrangThaiHienThi
                                            </span>
                                        }
                                    </td>

                                    <td>@item.GhiChu</td>

                                    <td>

                                        @if (item.TrangThaiHienThi == "Đang mở")
                                        {
                                            <a asp-controller="HocSinh"
                                               asp-action="BatDauThi"
                                               asp-route-maDotThi="@item.MaDotThi"
                                               class="btn btn-success btn-sm">
                                                Vào thi
                                            </a>
                                        }
                                        else
                                        {
                                            <button class="btn btn-light btn-sm" disabled>
                                                Vào thi
                                            </button>
                                        }

                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>