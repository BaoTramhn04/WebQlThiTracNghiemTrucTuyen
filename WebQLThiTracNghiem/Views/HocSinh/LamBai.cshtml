@{
    Layout = "~/Views/Shared/_LayoutHocSinh.cshtml";
    ViewData["Title"] = "Làm bài thi";
}

<div class="exam-header mb-4">
    <div>
        <h5 class="mb-1">Đề thi Toán 12 lần 1</h5>
        <div class="text-muted">Môn: Toán | Thời gian: 15 phút</div>
    </div>
    <div class="exam-timer">00:14:35</div>
</div>

<div class="row g-4">
    <div class="col-lg-9">
        <div class="question-card">
            <div class="question-title">Câu 1. Giá trị của 2 + 3 là bao nhiêu?</div>
            <div class="answer-list">
                <label class="answer-item"><input type="radio" name="c1" /> A. 4</label>
                <label class="answer-item"><input type="radio" name="c1" /> B. 5</label>
                <label class="answer-item"><input type="radio" name="c1" /> C. 6</label>
                <label class="answer-item"><input type="radio" name="c1" /> D. 7</label>
            </div>
        </div>

        <div class="question-card">
            <div class="question-title">Câu 2. Đạo hàm của x² là gì?</div>
            <div class="answer-list">
                <label class="answer-item"><input type="radio" name="c2" /> A. x</label>
                <label class="answer-item"><input type="radio" name="c2" /> B. 2x</label>
                <label class="answer-item"><input type="radio" name="c2" /> C. x²</label>
                <label class="answer-item"><input type="radio" name="c2" /> D. 2</label>
            </div>
        </div>

        <div class="question-card">
            <div class="question-title">Câu 3. Logarit cơ số 10 của 100 bằng bao nhiêu?</div>
            <div class="answer-list">
                <label class="answer-item"><input type="radio" name="c3" /> A. 1</label>
                <label class="answer-item"><input type="radio" name="c3" /> B. 2</label>
                <label class="answer-item"><input type="radio" name="c3" /> C. 10</label>
                <label class="answer-item"><input type="radio" name="c3" /> D. 100</label>
            </div>
        </div>

        <div class="d-flex justify-content-end">
            <a asp-controller="HocSinh" asp-action="KetQua" class="btn btn-danger btn-lg">Nộp bài</a>
        </div>
    </div>

    <div class="col-lg-3">
        <div class="card custom-card sticky-panel">
            <div class="card-header fw-semibold">Điều hướng câu hỏi</div>
            <div class="card-body">
                <div class="question-nav">
                    <button class="q-btn active">1</button>
                    <button class="q-btn">2</button>
                    <button class="q-btn">3</button>
                    <button class="q-btn">4</button>
                    <button class="q-btn">5</button>
                    <button class="q-btn">6</button>
                    <button class="q-btn">7</button>
                    <button class="q-btn">8</button>
                    <button class="q-btn">9</button>
                    <button class="q-btn">10</button>
                </div>
            </div>
        </div>
    </div>
</div>