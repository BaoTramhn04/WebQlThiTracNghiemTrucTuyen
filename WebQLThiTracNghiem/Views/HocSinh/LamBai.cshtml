@model WebQLThiTracNghiem.Models.ViewModels.LamBaiThiViewModel

@{
    Layout = null;
    ViewData["Title"] = "Làm bài thi";
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">


<div class="exam-header-pro mb-4">
    <div class="d-flex align-items-center gap-4">

        <img src="@Url.Content(string.IsNullOrEmpty(ViewBag.AnhDaiDien)
                 ? "~/images/avatar-default.png"
                 : "~/Avatar/" + ViewBag.AnhDaiDien)"
             class="avatar-big" />

        <div class="student-info-grid">
            <div><b>Họ tên:</b> @ViewBag.HoTen</div>
            <div><b>Mã HS:</b> @ViewBag.MaHocSinh</div>
            <div><b>SBD:</b> @ViewBag.SoBaoDanh</div>
            <div><b>Môn:</b> @Model.MonThi</div>
            <div><b>Đợt thi:</b> @Model.TenDotThi</div>
            <div><b>Thời gian:</b> @Model.ThoiGianLamBai phút</div>
        </div>

    </div>
</div>

<div id="popup" style="
position:fixed;inset:0;background:rgba(0,0,0,0.4);
display:none;justify-content:center;align-items:center;z-index:999999;">
    <div style="background:white;padding:25px;border-radius:16px;width:320px;text-align:center;">
        <h3 style="color:#4f46e5;">SmartExam</h3>
        <p id="popupMsg"></p>
        <button onclick="closePopup()" style="
            margin-top:10px;padding:8px 20px;background:#4f46e5;color:white;border:none;border-radius:8px;">
            OK
        </button>
    </div>
</div>
<div id="forceFullscreenOverlay" style="
    position: fixed;
    inset: 0;
    background: linear-gradient(135deg, #3b82f6, #60a5fa);
    color: white;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 99999;
    text-align: center;
">
    <div style="
        background: rgba(255,255,255,0.15);
        padding: 40px;
        border-radius: 20px;
        backdrop-filter: blur(10px);
    ">
        <h2 style="margin-bottom:10px;">🚀 Bắt đầu làm bài</h2>
       <div style="text-align:left;margin-bottom:20px;">
    ⚠️ Lưu ý:
    <ul>
        <li>Không thoát màn hình quá 3 lần</li>
        <li>Không copy / paste</li>
        <li>Không chuyển tab</li>
        <li>Vi phạm sẽ bị nộp bài</li>
    </ul>
</div>

        <button id="btnEnterFullscreen" style="
            padding: 12px 24px;
            font-size: 16px;
            background: white;
            color: #2563eb;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
        ">
            Vào toàn màn hình
        </button>
    </div>
</div>
<div class="container py-4">
    <form asp-controller="HocSinh" asp-action="NopBai" method="post" id="lamBaiForm">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="MaLuotThi" />
        <input type="hidden" asp-for="MaDotThi" />
        <input type="hidden" asp-for="TenDotThi" />
        <input type="hidden" asp-for="TenDeThi" />
        <input type="hidden" asp-for="MonThi" />
        <input type="hidden" asp-for="ThoiGianLamBai" />
        <input type="hidden" asp-for="ThoiDiemBatDau" />
        <input type="hidden" asp-for="ThoiDiemHetGio" />

        <div class="row g-4">
            <div class="col-lg-9">            
              

                @if (Model.DanhSachCauHoi == null || !Model.DanhSachCauHoi.Any())
                {
                    <div class="alert alert-warning">
                        Đề thi hiện chưa có câu hỏi.
                    </div>
                }
                else
                {
                    @for (int i = 0; i < Model.DanhSachCauHoi.Count; i++)
                    {
                        var cauHoi = Model.DanhSachCauHoi[i];

                        <input type="hidden" asp-for="DanhSachCauHoi[i].MaCauHoi" />
                        <input type="hidden" asp-for="DanhSachCauHoi[i].NoiDung" />
                        <input type="hidden" asp-for="DanhSachCauHoi[i].DiemCauHoi" />

                        <div class="student-page-card mb-4 question-card"
                             id="cau-@(i + 1)"
                             style="display:none">
                            <div class="student-page-card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <h3 class="student-page-title m-0" style="font-size: 22px;">
                                    Câu @(i + 1)
                                </h3>

                                <div class="form-check m-0">
                                    <input class="form-check-input review-checkbox"
                                           type="checkbox"
                                           id="review_@i"
                                           data-question-index="@i" />
                                    <label class="form-check-label fw-semibold" for="review_@i">
                                        Đánh dấu xem lại
                                    </label>
                                </div>
                            </div>

                            <div class="student-page-card-body">
                                <p class="mb-4" style="font-size: 20px;">
                                    <strong>Nội dung:</strong> @Html.Raw(cauHoi.NoiDung)
                                </p>

                                @if (cauHoi.DanhSachDapAn != null && cauHoi.DanhSachDapAn.Any())
                                {
                                    @for (int j = 0; j < cauHoi.DanhSachDapAn.Count; j++)
                                    {
                                        <input type="hidden" asp-for="DanhSachCauHoi[i].DanhSachDapAn[j].MaDapAn" />
                                        <input type="hidden" asp-for="DanhSachCauHoi[i].DanhSachDapAn[j].NoiDung" />

                                        <label class="answer-option d-flex align-items-center mb-3 p-3 rounded-3 border"
                                               for="dapAn_@cauHoi.DanhSachDapAn[j].MaDapAn">
                                            <input class="form-check-input me-3 question-radio"
                                                   type="radio"
                                                   asp-for="DanhSachCauHoi[i].MaDapAnChon"
                                                   value="@cauHoi.DanhSachDapAn[j].MaDapAn"
                                                   id="dapAn_@cauHoi.DanhSachDapAn[j].MaDapAn"
                                                   data-question-index="@i" />

                                            <span style="font-size: 18px;">
                                                @cauHoi.DanhSachDapAn[j].NoiDung
                                            </span>
                                        </label>
                                    }
                                }
                                else
                                {
                                    <div class="alert alert-warning mb-0">
                                        Câu hỏi này hiện chưa có đáp án.
                                    </div>
                                }
                            </div>
                        </div>
                    }
                  
                    <div class="d-flex justify-content-between align-items-center mt-4">

                        <div>
                            <button type="button" class="btn btn-secondary" onclick="prevQuestion()">← Trước</button>
                            <button type="button" class="btn btn-primary" onclick="nextQuestion()">Tiếp →</button>
                        </div>

                        <button type="button" id="btnNopBai"
                                class="btn btn-danger fw-bold"
                                style="background:linear-gradient(135deg,#ef4444,#dc2626);border:none;border-radius:12px;">
                            Nộp bài
                        </button>

                    </div>
                }
            </div>

            <div class="col-lg-3">
                <div class="student-page-card sticky-top" style="top: 20px;">
                    <div class="student-page-card-header">
                        <h3 class="student-page-title" style="font-size: 20px;">Theo dõi bài làm</h3>
                    </div>

                    <div class="student-page-card-body">
                        <div class="countdown-panel mb-4">
                            <div class="countdown-label">Thời gian còn lại</div>
                            <div id="countdownTimer" class="countdown-time">00:00:00</div>
                        </div>

                        <div class="mb-3">
                            <div class="d-flex align-items-center mb-2">
                                <span class="status-box status-empty me-2"></span>
                                <span>Chưa chọn</span>
                            </div>
                            <div class="d-flex align-items-center mb-2">
                                <span class="status-box status-done me-2"></span>
                                <span>Đã chọn</span>
                            </div>
                            <div class="d-flex align-items-center">
                                <span class="flag-demo me-2">🚩</span>
                                <span>Đánh dấu xem lại</span>
                            </div>
                        </div>

                        <hr />

                        <div class="question-palette">
                            @for (int i = 0; i < Model.DanhSachCauHoi.Count; i++)
                            {
                                <a href="javascript:void(0)"
                                   onclick="showQuestion(@i)"
                                   class="question-nav-btn status-empty"
                                   id="nav-question-@i">
                                    <span class="question-number">@(i + 1)</span>
                                    <span class="flag-icon" id="flag-@i"></span>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
<div id="confirmPopup" style="
position:fixed;inset:0;background:rgba(0,0,0,0.4);
display:none;justify-content:center;align-items:center;z-index:999999;">

    <div style="background:white;padding:25px;border-radius:16px;width:320px;text-align:center;">
        <h3 style="color:#4f46e5;">SmartExam</h3>
        <p id="confirmMsg"></p>

        <div style="margin-top:15px;display:flex;gap:10px;justify-content:center;">
            <button onclick="confirmYes()" style="
                padding:8px 20px;background:#22c55e;color:white;border:none;border-radius:8px;">
                Nộp bài
            </button>

            <button onclick="confirmNo()" style="
                padding:8px 20px;background:#e5e7eb;border:none;border-radius:8px;">
                Hủy
            </button>
        </div>
    </div>
</div>
<style>
body {
    background: #f8fafc;
    font-family: 'Segoe UI', sans-serif;
}

.container {
    max-width: 1200px;
}

.exam-header-pro {
    background: #ffffff;
    color: #1e293b;
    padding: 18px 22px;
    border-radius: 16px;
    margin-bottom: 20px;
    border: 1px solid #e5e7eb;
    box-shadow: 0 6px 20px rgba(0,0,0,0.06);
}

.avatar-big {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 2px solid #e5e7eb;
    object-fit: cover;
}

.student-info-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px 20px;
    font-size: 14px;
    color: #475569;
}

.student-page-card {
    border-radius: 16px;
    background: white;
    border: 1px solid #e5e7eb;
    box-shadow: 0 6px 20px rgba(0,0,0,0.05);
    overflow: hidden;
    margin-bottom: 20px;
}

.student-page-card-header {
    background: #f8fafc;
    padding: 14px 18px;
    font-weight: 600;
    border-bottom: 1px solid #e5e7eb;
}

.student-page-card-body {
    padding: 18px;
}

.student-page-title {
    font-size: 20px;
    font-weight: 700;
    color: #1e293b;
}

    .question-card {
        animation: fadeIn 0.2s ease;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }


.answer-option {
    display: flex;
    align-items: center;
    padding: 14px 16px;
    border-radius: 12px;
    border: none; 
    margin-bottom: 10px;
    cursor: pointer;
    transition: all 0.2s ease;
    background: #f8fafc;
}

.answer-option:hover {
    background: #eef2ff;
}

.answer-option.active {
    background: #dbeafe;
}

.question-radio {
    transform: scale(1.1);
}

button {
    border-radius: 10px !important;
}

.btn-primary {
    background: #3b82f6;
    border: none;
}

.btn-danger {
    background: #ef4444;
    border: none;
}

.countdown-panel {
    background: #f8fafc;
    border-radius: 14px;
    padding: 16px;
    text-align: center;
    margin-bottom: 20px;
    border: 1px solid #e5e7eb;
}

.countdown-label {
    font-size: 14px;
    font-weight: 600;
    color: #64748b;
}

.countdown-time {
    font-size: 32px;
    font-weight: 800;
    color: #1e293b;
    margin-top: 5px;
}

.status-box {
    width: 16px;
    height: 16px;
    border-radius: 4px;
    border: 1px solid #e5e7eb;
}

.status-empty {
    background: #f1f5f9;
}

.status-done {
    background: #22c55e !important;
    border-color: #22c55e !important;
}

.question-palette {
    display: grid;
    grid-template-columns: repeat(4, 1fr); 
    gap: 10px;
}

.question-nav-btn {
    height: 44px;
    border-radius: 10px;
    font-weight: 500;
    font-size: 13px;
    border: 1px solid #e5e7eb;

    display: flex;
    align-items: center;
    justify-content: center;

    background: #f8fafc;
    transition: all 0.2s ease;

    text-decoration: none; 
    color: #1e293b;
}

.question-nav-btn:hover {
    background: #eef2ff;
}

.question-nav-btn.active {
    background: #3b82f6;
    color: white;
}

.question-nav-btn,
.question-nav-btn:link,
.question-nav-btn:visited {
    text-decoration: none !important;
}

.flag-icon {
    font-size: 11px;
    margin-left: 3px;
}

.overlay {
    position: fixed;
    inset: 0;
    background: white;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 9999;
}

.overlay-box button {
    padding: 10px 20px;
    font-size: 16px;
    background: #3b82f6;
    color: white;
    border: none;
    border-radius: 8px;
}

    .success-popup {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.4);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 999999;
    }

    .success-box {
        background: white;
        padding: 35px 30px;
        border-radius: 18px;
        width: 360px;
        text-align: center;
        animation: scaleIn 0.3s ease;
    }

    @@keyframes scaleIn {
        from

    {
        transform: scale(0.7);
        opacity: 0;
    }

    to {
        transform: scale(1);
        opacity: 1;
    }

    }

    .checkmark-circle {
        width: 80px;
        height: 80px;
        margin: 0 auto 15px;
    }

    .checkmark {
        width: 80px;
        height: 80px;
        stroke: #22c55e;
        stroke-width: 3;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .checkmark-circle-bg {
        stroke: #22c55e;
        stroke-width: 3;
        stroke-dasharray: 157;
        stroke-dashoffset: 157;
        animation: strokeCircle 0.5s ease forwards;
    }

    .checkmark-check {
        stroke-dasharray: 48;
        stroke-dashoffset: 48;
        animation: strokeCheck 0.4s ease 0.5s forwards;
    }

    @@keyframes strokeCircle {
        to

    {
        stroke-dashoffset: 0;
    }

    }

    @@keyframes strokeCheck {
        to

    {
        stroke-dashoffset: 0;
    }

    }

    .success-box h3 {
        margin-top: 10px;
        font-size: 22px;
        color: #16a34a;
    }

    .success-box p {
        color: #475569;
        margin-top: 5px;
    }

    .btn-ok {
        margin-top: 20px;
        padding: 10px 25px;
        border: none;
        border-radius: 10px;
        background: linear-gradient(135deg,#22c55e,#16a34a);
        color: white;
        font-weight: 600;
        cursor: pointer;
        transition: 0.2s;
    }

        .btn-ok:hover {
            transform: scale(1.05);
        }

</style>

<div id="submitSuccessPopup" class="success-popup">
    <div class="success-box">

        <div class="checkmark-circle">
            <svg viewBox="0 0 52 52" class="checkmark">
                <circle class="checkmark-circle-bg" cx="26" cy="26" r="25" fill="none" />
                <path class="checkmark-check" fill="none" d="M14 27l7 7 16-16" />
            </svg>
        </div>

        <h3>Nộp bài thành công</h3>
        <p>Bài thi của bạn đã được ghi nhận.</p>

        <button onclick="goToLogin()" class="btn-ok">
            OK
        </button>
    </div>
</div>

    <script>
        let daNop = false;
        let daTuDongNop = false;
        const maLuotThi = "@Model.MaLuotThi";
let soLanViPham = parseInt(localStorage.getItem("viPham_" + maLuotThi)) || 0;   
const MAX_VI_PHAM = 3;
        let dangTrongFullscreen = false;

        
        const STORAGE_KEY = "answers_" + maLuotThi;

function saveAnswers() {
    const answers = {};
    document.querySelectorAll(".question-radio:checked").forEach(r => {
        answers[r.name] = r.value;
    });
    localStorage.setItem(STORAGE_KEY, JSON.stringify(answers));
}

function loadAnswers() {
    const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || "{}");

    document.querySelectorAll(".question-radio").forEach(radio => {
        if (saved[radio.name] == radio.value) {

            radio.checked = true;

            radio.closest(".answer-option")?.classList.add("active");

            const index = radio.dataset.questionIndex;

            document.getElementById("nav-question-" + index)
                ?.classList.add("status-done");
        }
    });
}
        document.addEventListener("DOMContentLoaded", () => {
            loadAnswers();
             const daBatDau = localStorage.getItem("started_" + maLuotThi);

            if (daBatDau === "true") {
    document.getElementById("forceFullscreenOverlay").style.display = "none";
    dangTrongFullscreen = true;

    setTimeout(() => {
        forceFullscreenLoop();
    }, 500);
            }
            history.pushState(null, null, location.href);
           window.onpopstate = function () {
    history.pushState(null, null, location.href);

    canhBaoGianLan();
    showForceFullscreenOverlay();
    forceFullscreenLoop();
};
 
        
  
            showQuestion(0);

            const overlay = document.getElementById("forceFullscreenOverlay");
            const btn = document.getElementById("btnEnterFullscreen");

            btn.onclick = async () => {
                try {
                    await document.documentElement.requestFullscreen();

                    overlay.style.display = "none";
                    dangTrongFullscreen = true;
        localStorage.setItem("started_" + maLuotThi, "true");
                } catch {
                    showPopup("Không bật được fullscreen!");
                }
            };

            document.querySelectorAll(".question-radio").forEach(radio=>{
             radio.addEventListener("change", function(){

    saveAnswers(); 

    const parent = this.closest(".question-card");


                    parent.querySelectorAll(".answer-option")
                        .forEach(l => l.classList.remove("active"));

                    this.closest(".answer-option").classList.add("active");

                    const index = this.dataset.questionIndex;

                    document.getElementById("nav-question-" + index)
                        ?.classList.add("status-done");
                });
                 
            });
              setInterval(() => {
    if (!daNop) {
        saveAnswers();
    }
}, 3000); 

         window.addEventListener("beforeunload", function () {
    if (!daNop) {
        saveAnswers();
    }
});
           
            document.querySelectorAll(".review-checkbox").forEach(cb=>{
                cb.addEventListener("change", function(){

                    const index = this.dataset.questionIndex;
                    document.getElementById("flag-" + index).innerText =
                        this.checked ? "🚩" : "";
                });
            });

            document.getElementById("btnNopBai")?.addEventListener("click", function (e) {
                e.preventDefault();
                confirmSubmitExam();
            });

            startCountdown();
        });

        async function forceFullscreenLoop() {

            if (document.fullscreenElement) return;

            try {
                await document.documentElement.requestFullscreen();
                dangTrongFullscreen = true;
            } catch {
                setTimeout(forceFullscreenLoop, 1000);
            }
        }

           function submitFormSafe() {
        return; 
    }

        function countUnanswered() {
            const total = document.querySelectorAll(".question-nav-btn").length;
            const answered = document.querySelectorAll(".question-radio:checked").length;
            return total - answered;
        }

          function confirmSubmitExam() {

        const conLai = countUnanswered();

        let msg = "Bạn có chắc muốn nộp bài?";
        if (conLai > 0) {
            msg += `\n⚠️ Còn ${conLai} câu chưa làm`;
        }

        showConfirmPopup(msg, () => {
            daNop = true;

            const form = document.getElementById("lamBaiForm");
            const formData = new FormData(form);

            fetch(form.action, {
                method: "POST",
                body: formData
            })
            .then(() => {
                showSubmitSuccessPopup(); 
            })
            .catch(() => {
                alert("Lỗi khi nộp bài!");
            });
        });
    }

        document.addEventListener("keydown", function (e) {

            if (daNop) return;

                if (e.key === "F12") {
        e.preventDefault();
        canhBaoGianLan();
    }
            if (e.key === "Escape") {
                e.preventDefault();
                canhBaoGianLan();
                showForceFullscreenOverlay();
                forceFullscreenLoop();
            }

            if (e.key === "F5" || (e.ctrlKey && e.key.toLowerCase() === "r")) {
                e.preventDefault();
                canhBaoGianLan();
                showForceFullscreenOverlay();
                forceFullscreenLoop();
            }

            if (e.key === "Backspace") {
                const tag = e.target.tagName.toLowerCase();

                if (tag !== "input" && tag !== "textarea") {
                    e.preventDefault();
                    canhBaoGianLan();
                    showForceFullscreenOverlay();
                    forceFullscreenLoop();
                }
            }
        });

        document.addEventListener("fullscreenchange", function () {

            if (daNop) return;

            if (!document.fullscreenElement) {
                canhBaoGianLan();
                showForceFullscreenOverlay();
                forceFullscreenLoop();
            }
        });

              window.addEventListener("blur", function () {

            if (daNop) return;

            setTimeout(() => {
                if (!document.hasFocus()) {
                    canhBaoGianLan();
                    showForceFullscreenOverlay();
                    forceFullscreenLoop();
                }
            }, 300);

        });

        function showForceFullscreenOverlay() {

            let overlay = document.getElementById("forceFullscreenBack");
            if (overlay) return;

            overlay = document.createElement("div");
            overlay.id = "forceFullscreenBack";

            overlay.style = `
                position:fixed;
                inset:0;
                background:linear-gradient(135deg,#1e3a8a,#3b82f6);
                display:flex;
                justify-content:center;
                align-items:center;
                z-index:999999;
                flex-direction:column;
            `;

            overlay.innerHTML = `
                <h2 style="color:white;margin-bottom:20px;">
                    SmartExam - Quay lại toàn màn hình
                </h2>

                <button id="btnBackFullscreen"
                    style="padding:15px 30px;font-size:18px;background:white;color:#1e3a8a;border:none;border-radius:10px;">
                    🔄 Quay lại
                </button>
            `;

            document.body.appendChild(overlay);

            forceFullscreenLoop();

            document.getElementById("btnBackFullscreen").onclick = async () => {
                try {
                    await document.documentElement.requestFullscreen();
                    overlay.remove();
                } catch {
                    showPopup("Không thể fullscreen!");
                }
            };
        }

        function startCountdown() {

            const el = document.getElementById("countdownTimer");
    const end = new Date("@Model.ThoiDiemHetGio.ToString("yyyy-MM-ddTHH:mm:ss.fff")").getTime();
    function tick() {

                const d = end - Date.now();

                  if (d <= 0) {
        el.innerHTML = "00:00:00";

        if (!daNop) {
            daNop = true;

            const form = document.getElementById("lamBaiForm");
            const formData = new FormData(form);

            fetch(form.action, {
                method: "POST",
                body: formData
            })
            .then(() => {
                showSubmitSuccessPopup();
            })
            .catch(() => {
                alert("Lỗi khi nộp bài!");
            });
        }
        return;
    }

                const h = Math.floor(d / 3600000);
                const m = Math.floor((d % 3600000) / 60000);
                const s = Math.floor((d % 60000) / 1000);

                el.innerHTML =
                    `${String(h).padStart(2,"0")}:${String(m).padStart(2,"0")}:${String(s).padStart(2,"0")}`;
            }

            tick();
            setInterval(tick, 1000);
        }
           function showSubmitSuccessPopup() {

        const popup = document.getElementById("submitSuccessPopup");
        popup.style.display = "flex";

        
    }

        let currentQuestion = 0;

        function showQuestion(index){

            document.querySelectorAll(".question-card")
                .forEach(q => q.style.display = "none");

            document.querySelectorAll(".question-nav-btn")
                .forEach(b => b.classList.remove("active"));

            const el = document.getElementById("cau-" + (index + 1));
            if(el) el.style.display = "block";

            document.getElementById("nav-question-" + index)
                ?.classList.add("active");

            currentQuestion = index;
        }

        function nextQuestion(){
            if(currentQuestion < document.querySelectorAll(".question-card").length - 1){
                showQuestion(currentQuestion + 1);
            }
        }

        function prevQuestion(){
            if(currentQuestion > 0){
                showQuestion(currentQuestion - 1);
            }
        }

      function showPopup(msg){
    document.getElementById("popupMsg").innerHTML = `
        <div style="color:#dc2626;font-weight:600;">
            ⚠️ ${msg}
        </div>
        <div style="margin-top:10px;color:#374151;">
            Hành vi này có thể bị coi là gian lận.
        </div>
    `;
    document.getElementById("popup").style.display = "flex";
}

        function closePopup(){
            document.getElementById("popup").style.display = "none";
        }

        let confirmCallback = null;

        function showConfirmPopup(msg, callback){
            document.getElementById("confirmMsg").innerText = msg;
            document.getElementById("confirmPopup").style.display = "flex";
            confirmCallback = callback;
        }

        function confirmYes(){
            document.getElementById("confirmPopup").style.display = "none";
            if(confirmCallback) confirmCallback();
        }

        function confirmNo(){
            document.getElementById("confirmPopup").style.display = "none";
        }
