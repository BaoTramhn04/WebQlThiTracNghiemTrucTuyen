        window.location.href = "/Home/DangNhap"; 
    }
        function submitAndRedirect() {
        submitFormSafe(); 

        setTimeout(() => {
            redirectHome(); 
        }, 300);
    }
    function canhBaoGianLan() {

    soLanViPham++;

localStorage.setItem("viPham_" + maLuotThi, soLanViPham);

       if (soLanViPham >= MAX_VI_PHAM) {

        showPopup(`🚫 Bạn đã vi phạm ${soLanViPham} lần! Hệ thống sẽ tự động nộp bài.`);

        setTimeout(() => {
            if (!daNop) {
                daNop = true;

                const form = document.getElementById("lamBaiForm");
                const formData = new FormData(form);

                fetch(form.action, {
                    method: "POST",
                    body: formData
                })
                .then(() => {
                    showSubmitSuccessPopup();
                })
                .catch(() => {
                    alert("Lỗi khi nộp bài!");
                });
            }
        }, 1500);

        return;
    }

    showPopup(`⚠️ Bạn đã vi phạm ${soLanViPham} lần!\nCòn ${MAX_VI_PHAM - soLanViPham} lần trước khi bị nộp bài.`);
}
document.addEventListener("copy", e => e.preventDefault());
document.addEventListener("paste", e => e.preventDefault());

document.addEventListener("keydown", function (e) {

    if (e.ctrlKey && e.key.toLowerCase() === "c") {
        e.preventDefault();
        canhBaoGianLan();
    }

    if (e.ctrlKey && e.key.toLowerCase() === "v") {
        e.preventDefault();
        canhBaoGianLan();
    }
});
    document.addEventListener("contextmenu", function (e) {
        e.preventDefault();
        canhBaoGianLan();
        });
        function goToLogin() {

        localStorage.removeItem(STORAGE_KEY);
        localStorage.removeItem("viPham_" + maLuotThi);
        localStorage.removeItem("started_" + maLuotThi);

        window.location.href = "/Home/DangNhap";
    }
