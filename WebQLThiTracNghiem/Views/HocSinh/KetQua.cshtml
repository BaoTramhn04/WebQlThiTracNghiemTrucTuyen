@{
    Layout = "~/Views/Shared/_LayoutHocSinh.cshtml";
    ViewData["Title"] = "Kết quả bài thi";
}

<div class="result-card">
    <h2>Kết quả bài thi</h2>
    <p class="text-muted">Đề thi Toán 12 lần 1</p>

    <div class="result-score">8.0 / 10</div>

    <div class="row mt-4">
        <div class="col-md-4">
            <div class="mini-result">
                <h5>10</h5>
                <p>Tổng số câu</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="mini-result">
                <h5>8</h5>
                <p>Câu đúng</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="mini-result">
                <h5>2</h5>
                <p>Câu sai</p>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-controller="HocSinh" asp-action="DotThi" class="btn btn-primary">Quay lại danh sách đợt thi</a>
    </div>
</div>