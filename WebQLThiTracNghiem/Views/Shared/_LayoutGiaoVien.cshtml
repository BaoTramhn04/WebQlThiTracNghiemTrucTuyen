@inject WebQLThiTracNghiem.Data.ApplicationDbContext _context
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Website thi trắc nghiệm</title>

    <!-- ICON -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/giaovien.css" asp-append-version="true" />

    <style>

        /* ===== SIDEBAR ===== */
        .gv-sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 250px;
            height: 100vh;
            background: linear-gradient(180deg, #1e3a8a, #1e40af);
            color: #fff;
            transition: 0.3s;
            overflow-y: auto;
        }

            /* collapse */
            .gv-sidebar.collapsed {
                width: 80px;
            }

        /* ===== USER BOX ===== */
        .gv-user-box {
            text-align: center;
            padding: 20px 10px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        /* avatar */
        .gv-avatar {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid rgba(255,255,255,0.3);
            margin-bottom: 10px;
        }

        /* tên */
        .gv-user-name {
            font-weight: 600;
            font-size: 14px;
            color: #fff;
        }

        /* bộ môn */
        .gv-user-role {
            font-size: 13px;
            color: #cbd5f5;
        }

        /* collapse thì ẩn info */
        .gv-sidebar.collapsed .gv-user-name,
        .gv-sidebar.collapsed .gv-user-role {
            display: none;
        }

        /* ===== MENU ===== */
        .menu-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 12px;
            margin: 6px 10px;
            border-radius: 10px;
            color: white;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.25s ease;
        }

            /* hover */
            .menu-item:hover {
                background: rgba(255,255,255,0.15);
                transform: translateX(4px);
            }

            /* active */
            .menu-item.active {
                background: #3b82f6;
                box-shadow: 0 0 10px rgba(59,130,246,0.5);
            }

            /* icon */
            .menu-item i {
                width: 20px;
                height: 20px;
            }

        /* collapse menu */
        .gv-sidebar.collapsed .menu-item span {
            display: none;
        }

        .gv-sidebar.collapsed .menu-item {
            justify-content: center;
        }

        /* ===== SUBMENU ===== */
        .submenu {
            padding-left: 10px;
            margin-top: 2px;
        }

        /* item */
        .submenu-item {
            display: block;
            padding: 8px 12px;
            margin: 4px 10px;
            border-radius: 8px;
            font-size: 14px;
            color: #dbeafe;
            text-decoration: none;
            transition: all 0.2s ease;
        }

            /* hover submenu */
            .submenu-item:hover {
                background: rgba(255,255,255,0.15);
                padding-left: 16px;
            }

        /* active submenu */
        .active-sub {
            background: #2563eb;
            color: #fff !important;
        }

        /* ===== MAIN ===== */
        .gv-main {
            margin-left: 250px;
            transition: 0.3s;
        }

            .gv-main.expand {
                margin-left: 80px;
            }

        /* ===== HEADER ===== */
        .gv-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #fff;
            padding: 15px 20px;
            border-bottom: 1px solid #eee;
        }

        /* left */
        .gv-header-left {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* button toggle */
        .btn-toggle {
            border: none;
            background: #f3f4f6;
            border-radius: 8px;
            padding: 6px 10px;
            cursor: pointer;
        }

            /* hover button */
            .btn-toggle:hover {
                background: #e5e7eb;
            }

    </style>
</head>

<body>
    @{
        var maNguoiDung = Context.Session.GetInt32("MaNguoiDung");

        // 🔥 lấy từ session trước (nhanh)
        var avatar = Context.Session.GetString("Avatar");

        // 🔥 nếu chưa có thì mới query DB (chỉ 1 lần)
        if (string.IsNullOrEmpty(avatar) && maNguoiDung != null)
        {
            avatar = _context.HoSoCaNhan
            .Where(x => x.MaNguoiDung == maNguoiDung)
            .Select(x => x.AnhDaiDien)
            .FirstOrDefault();
        }
    }

<div class="gv-layout">

<aside class="gv-sidebar">

    <!-- USER BOX -->
    <div class="gv-user-box">
                <img src="@Url.Content(string.IsNullOrEmpty(avatar)
                             ? "~/images/avatar-default.png"
                             : "~/Avatar/" + avatar)"
                     class="gv-avatar" />

        <div class="gv-user-name">
            @(Context.Session.GetString("TenNguoiDung") ?? "Giáo viên")
        </div>

        <div class="gv-user-role">
            @(Context.Session.GetString("BoMonDay") ?? "Chưa cập nhật")
        </div>

    </div>

    <!-- MENU -->
    <nav>

        @{
            var action = ViewContext.RouteData.Values["action"]?.ToString();
        }

        <!-- Tổng quan -->
        <a asp-action="BangDieuKhien"
           class="menu-item @(action == "BangDieuKhien" ? "active" : null)">
            <i data-lucide="layout-dashboard"></i>
            <span>Tổng quan</span>
        </a>

        <!-- Tài khoản -->
        <a asp-action="ThongTinCaNhan"
           class="menu-item @(action == "ThongTinCaNhan" ? "active" : null)">
            <i data-lucide="user"></i>
            <span>Tài khoản cá nhân</span>
        </a>

        <!-- Học sinh -->
        <a asp-action="HocSinh"
           class="menu-item @(action == "HocSinh" ? "active" : null)">
            <i data-lucide="users"></i>
            <span>Quản lý học sinh</span>
        </a>

        <!-- ================= CÂU HỎI ================= -->
        @{
            var isCauHoi = action == "CauHoi"
                        || action == "TaoCauHoi"
                        || action == "ImportCauHoi";
        }

        <div class="menu-item @(isCauHoi ? "active" : null)"
             onclick="toggleSubMenu(this)">
            <i data-lucide="book-open"></i>
            <span>Quản lý câu hỏi</span>
        </div>

        <div class="submenu" style="display:@(isCauHoi ? "block" : "none")">

            <a asp-controller="GiaoVien" asp-action="CauHoi"
               class="submenu-item @(action == "CauHoi" ? "active-sub" : null)">
                📋 Danh sách câu hỏi
            </a>

            <a asp-controller="GiaoVien" asp-action="TaoCauHoi"
               class="submenu-item @(action == "TaoCauHoi" ? "active-sub" : null)">
                ➕ Thêm câu hỏi
            </a>

            <a asp-controller="GiaoVien" asp-action="ImportCauHoi"
               class="submenu-item @(action == "ImportCauHoi" ? "active-sub" : null)">
                📥 Import câu hỏi
            </a>

        </div>

        <!-- ================= ĐỀ THI ================= -->
        @{
            var isDeThi = action == "DeThi"
                       || action == "TaoDeThi"
                       || action == "ImportDeThi"
                       || action == "ChiTietDeThi";
        }

        <div class="menu-item @(isDeThi ? "active" : null)"
             onclick="toggleSubMenu(this)">
            <i data-lucide="file-text"></i>
            <span>Quản lý đề thi</span>
        </div>

        <div class="submenu" style="display:@(isDeThi ? "block" : "none")">

            <a asp-controller="GiaoVien" asp-action="DeThi"
               class="submenu-item @(action == "DeThi" ? "active-sub" : null)">
                📄 Danh sách đề thi
            </a>

            <a asp-controller="GiaoVien" asp-action="TaoDeThi"
               class="submenu-item @(action == "TaoDeThi" ? "active-sub" : null)">
                ➕ Tạo đề thi
            </a>

            <a asp-controller="GiaoVien" asp-action="ImportDeThi"
               class="submenu-item @(action == "ImportDeThi" ? "active-sub" : null)">
                📥 Import đề thi
            </a>

        </div>

        <!-- Đợt thi -->
        <a asp-action="DotThi"
           class="menu-item @(action == "DotThi" ? "active" : null)">
            <i data-lucide="calendar"></i>
            <span>Quản lý đợt thi</span>
        </a>

        <!-- Thống kê -->
        <a asp-action="ThongKe"
           class="menu-item @(action == "ThongKe" ? "active" : null)">
            <i data-lucide="bar-chart-3"></i>
            <span>Quản lý thống kê</span>
        </a>

    </nav>

</aside>
        <!-- MAIN -->
        <div class="gv-main">

            <!-- HEADER -->
            <header class="gv-header">

                <div class="gv-header-left">
                    <button class="btn-toggle" onclick="toggleSidebar()">☰</button>

                    <div>
                        <small class="text-muted">Khu vực giáo viên</small>
                    </div>
                </div>

                <div class="d-flex align-items-center gap-3">

                    <a asp-controller="Home" asp-action="TrangChu"
                       class="btn btn-outline-primary btn-sm"
                       onclick="return confirm('Bạn có muốn quay về trang chủ không?')">
                        Trang chủ
                    </a>
                    <a asp-controller="Auth" asp-action="DangXuat"
                       class="btn btn-danger btn-sm"
                       onclick="return confirm('Bạn có muốn đăng xuất không?')">
                        Đăng xuất
                    </a>

                </div>

            </header>

            <!-- CONTENT -->
            <main class="p-3">
                @RenderBody()
            </main>

        </div>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function toggleSidebar() {
            document.querySelector(".gv-sidebar").classList.toggle("collapsed");
            document.querySelector(".gv-main").classList.toggle("expand");
        }

        // load icon
        lucide.createIcons();
    </script>
    @RenderSection("Scripts", required: false)
    <script>
        window.MathJax = {
            tex: {
                inlineMath: [['\\(', '\\)']],
                displayMath: [['$$', '$$']]
            }
        };
    </script>

    <script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
    <script>
    function toggleSubMenu(el) {
        const next = el.nextElementSibling;
        next.style.display = next.style.display === "block" ? "none" : "block";
    }
</script>
</body>
</html>