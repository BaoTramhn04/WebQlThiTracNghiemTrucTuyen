<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Website thi trắc nghiệm</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/giaovien.css" asp-append-version="true" />

    <style>
        .gv-user-info {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 2px;
            margin-right: 10px;
        }

        .gv-user-badge {
            display: inline-block;
        }

        .gv-subject-text {
            font-size: 13px;
            color: #6b7280;
            font-weight: 500;
        }

        .gv-toast-success {
            background: linear-gradient(135deg, #dcfce7, #bbf7d0);
            color: #166534;
            border: 1px solid #86efac;
            border-radius: 12px;
            padding: 12px 16px;
            margin-bottom: 16px;
            font-weight: 600;
            box-shadow: 0 8px 20px rgba(22, 101, 52, 0.08);
            animation: gvFadeInDown 0.4s ease;
        }

        @@keyframes gvFadeInDown {
            from {
                opacity: 0;
                transform: translateY(-8px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        /* ===== FIX SIDEBAR ===== */
        .gv-sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 260px;
            height: 100vh;
            overflow-y: auto;
            z-index: 1000;
            background: linear-gradient(180deg, #1e3a5f, #2563eb);
            color: #fff;
        }


          
        /* Đẩy nội dung sang phải */
        .gv-main {
            margin-left: 260px;
        }

        /* Đảm bảo layout không bị lệch */
        .gv-layout {
            display: flex;
        }

        /* Menu đẹp hơn */
        .gv-menu a.active {
            background-color: #2563eb;
            color: #fff;
            border-radius: 8px;
        }

        .gv-menu a:hover {
            background-color: #1e3a5f;
            color: #fff;
        }

        /* ===== TAB STYLE ===== */
        .gv-tab {
            border-bottom: none;
            gap: 10px;
        }

            .gv-tab .nav-link {
                border: none;
                background: #f3f4f6;
                color: #374151;
                padding: 8px 16px;
                border-radius: 8px;
                font-weight: 500;
                transition: all 0.2s ease;
            }

                .gv-tab .nav-link:hover {
                    background: #e0e7ff;
                    color: #1d4ed8;
                }

                .gv-tab .nav-link.active {
                    background: linear-gradient(135deg, #2563eb, #1e3a8a);
                    color: #fff;
                    font-weight: 600;
                    box-shadow: 0 4px 10px rgba(37, 99, 235, 0.3);
                }
    </style>
</head>
<body>

    <div class="gv-layout">

        <!-- Sidebar -->
        <aside class="gv-sidebar">

            <div class="gv-sidebar-top">
                <div class="gv-logo-box">
                    <img src="~/images/logo-school.png" alt="Logo" />
                </div>

                <div class="gv-brand">
                    <div class="gv-brand-sub">TRƯỜNG THPT ABC</div>
                    <div class="gv-brand-title">KHU VỰC GIÁO VIÊN</div>
                </div>
            </div>

            <nav class="gv-menu">

                <a asp-controller="GiaoVien" asp-action="BangDieuKhien"
                   class="@(ViewContext.RouteData.Values["action"]?.ToString() == "BangDieuKhien" ? "active" : "")">
                    Bảng điều khiển
                </a>

                <a asp-controller="GiaoVien" asp-action="ThongTinCaNhan"
                   class="@(ViewContext.RouteData.Values["action"]?.ToString() == "ThongTinCaNhan" ? "active" : "")">
                    Thông tin cá nhân
                </a>

                <a asp-controller="GiaoVien" asp-action="HocSinh"
                   class="@(ViewContext.RouteData.Values["action"]?.ToString() == "HocSinh" ? "active" : "")">
                    Quản lý học sinh
                </a>

                <a asp-controller="GiaoVien" asp-action="CauHoi"
                   class="@(ViewContext.RouteData.Values["action"]?.ToString() == "CauHoi" ? "active" : "")">
                    Quản lý câu hỏi
                </a>

                <a asp-controller="GiaoVien" asp-action="DeThi"
                   class="@(ViewContext.RouteData.Values["action"]?.ToString() == "DeThi" ? "active" : "")">
                    Quản lý đề thi
                </a>

                <a asp-controller="GiaoVien" asp-action="DotThi"
                   class="@(ViewContext.RouteData.Values["action"]?.ToString() == "DotThi" ? "active" : "")">
                    Quản lý đợt thi
                </a>

                <a asp-controller="GiaoVien" asp-action="ThongKe"
                   class="@(ViewContext.RouteData.Values["action"]?.ToString() == "ThongKe" ? "active" : "")">
                    Thống kê
                </a>

            </nav>

        </aside>

        <!-- Main -->
        <div class="gv-main">

            <header class="gv-header">

                <div>
                    <h1>@ViewData["Title"]</h1>
                    <p>Khu vực quản lý dành cho giáo viên</p>
                </div>

                <div class="gv-header-right">

                    <div class="gv-user-info">
                        <span class="gv-user-badge">
                            Xin chào, @(Context.Session.GetString("TenNguoiDung") ?? "Giáo viên")
                        </span>

                        <span class="gv-subject-text">
                            Bộ môn giảng dạy: @(Context.Session.GetString("BoMonDay") ?? "Chưa cập nhật")
                        </span>
                    </div>

                    <a asp-controller="Home" asp-action="TrangChu"
                       class="btn btn-outline-primary">
                        Trang chủ
                    </a>

                    <a asp-controller="Auth" asp-action="DangXuat"
                       class="btn btn-danger">
                        Đăng xuất
                    </a>

                </div>

            </header>

            <main class="gv-content">

                @if (TempData["LoginSuccess"] != null)
                {
                    <div class="gv-toast-success" id="gvLoginToast">
                        @TempData["LoginSuccess"]
                    </div>
                }

                @RenderBody()
            </main>

        </div>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        setTimeout(function () {
            var toast = document.getElementById("gvLoginToast");
            if (toast) {
                toast.style.transition = "opacity 0.5s ease";
                toast.style.opacity = "0";
                setTimeout(function () {
                    toast.remove();
                }, 500);
            }
        }, 2500);
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>