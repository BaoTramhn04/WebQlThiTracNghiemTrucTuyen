<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" />

    <style>
        .user-info-box {
            text-align: right;
            line-height: 1.4;
        }

            .user-info-box .welcome-text {
                font-weight: 600;
                color: #1f2937;
            }

            .user-info-box .subject-text {
                font-size: 13px;
                color: #6b7280;
            }

        .login-success-toast {
            background: #d1fae5;
            color: #065f46;
            border: 1px solid #a7f3d0;
            padding: 12px 16px;
            border-radius: 10px;
            margin-bottom: 16px;
            font-weight: 500;
            animation: fadeIn 0.4s ease;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-8px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }


        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 250px;
            height: 100vh;
            overflow-y: auto;
            background: #1e3a8a;
            color: white;
            padding: 20px;
            z-index: 9999;
        }

        .sidebar a {
                display: block;
                color: white;
                padding: 10px;
                text-decoration: none;
                border-radius: 6px;
                margin-bottom: 5px;
            }

        .sidebar a:hover {
               background: rgba(255,255,255,0.2);
           }

        .sidebar-title {
            font-weight: bold;
            font-size: 18px;
            margin-bottom: 15px;
        }

        .content {
            margin-left: 250px;
            padding: 20px;
        }
     
    
    </style>
</head>

<body>

    <div class="admin-wrapper">

        <!-- SIDEBAR -->
        <div class="sidebar">

            <div class="sidebar-title">
                Quản trị hệ thống
            </div>

            <a asp-controller="Admin" asp-action="BangDieuKhien">
                Dashboard
            </a>

            <!-- MENU CHA -->
            <a href="javascript:void(0)" onclick="toggleUserMenu()">
                Quản lý người dùng ▼
            </a>

            <!-- MENU CON -->
            <div id="user-submenu" style="display:none; padding-left:15px;">
                <a asp-controller="Admin" asp-action="DanhSachGiaoVien">
                    - Quản lý Giáo viên
                </a>

                <a asp-controller="Admin" asp-action="DanhSachHocSinh">
                    - Quản lý Học sinh
                </a>
            </div>
            <a asp-controller="Admin" asp-action="Lop">
                Quản lý lớp
            </a>
            <a asp-controller="Admin" asp-action="MonHoc">
                Quản lý môn học
            </a>
            <a asp-controller="Admin" asp-action="ChuyenDe">
                Quản lý chuyên đề
            </a>
            <a asp-controller="Admin" asp-action="NguoiDung">
                Quản lý tài khoản
            </a>
            <a asp-controller="Admin" asp-action="PhanCongGiangDay">
                Phân công giảng dạy
            </a>

            <a asp-controller="Auth" asp-action="DangXuat">
                Đăng xuất
            </a>

        </div>

        <!-- CONTENT -->
        <div class="content">

            <div class="topbar">

                <h5>@ViewData["Title"]</h5>

                <div class="user-info-box">
                    <div class="welcome-text">
                        Xin chào, @(Context.Session.GetString("TenNguoiDung") ?? "Admin")
                    </div>
                   
                </div>

            </div>

            <div class="main">

                @if (TempData["LoginSuccess"] != null)
                {
                    <div class="login-success-toast" id="loginSuccessToast">
                        @TempData["LoginSuccess"]
                    </div>
                }

                @RenderBody()

            </div>

        </div>

    </div>

    <script>
        setTimeout(function () {
            var toast = document.getElementById("loginSuccessToast");
            if (toast) {
                toast.style.transition = "opacity 0.5s ease";
                toast.style.opacity = "0";
                setTimeout(function () {
                    toast.remove();
                }, 500);
            }
        }, 2500);
    </script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleUserMenu() {
            var menu = document.getElementById("user-submenu");

            if (menu.style.display === "none") {
                menu.style.display = "block";
            } else {
                menu.style.display = "none";
            }
        }
    </script>
    
</body>
</html>