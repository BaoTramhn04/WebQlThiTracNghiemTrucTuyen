<!DOCTYPE html>
<html lang="vi">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" />

    <style>
        .user-info-box {
            text-align: right;
            line-height: 1.4;
        }

            .user-info-box .welcome-text {
                font-weight: 600;
                color: #1f2937;
            }

            .user-info-box .subject-text {
                font-size: 13px;
                color: #6b7280;
            }

        .login-success-toast {
            background: #d1fae5;
            color: #065f46;
            border: 1px solid #a7f3d0;
            padding: 12px 16px;
            border-radius: 10px;
            margin-bottom: 16px;
            font-weight: 500;
            animation: fadeIn 0.4s ease;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-8px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }


        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 250px;
            height: 100vh;
            overflow-y: auto;
            background: #1e3a8a;
            color: white;
            padding: 20px;
            z-index: 9999;
        }

            .sidebar a {
                display: block;
                color: white;
                padding: 10px;
                text-decoration: none;
                border-radius: 6px;
                margin-bottom: 5px;
            }

                .sidebar a:hover {
                    background: rgba(255,255,255,0.2);
                }

        .sidebar-title {
            font-weight: bold;
            font-size: 18px;
            margin-bottom: 15px;
        }

        .content {
            margin-left: 250px;
            padding: 20px;
        }

        
        .btn {
            padding: 10px 18px;
            border-radius: 8px;
            font-weight: 500;
        }

        .sidebar-avatar {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            object-fit: cover;
            background: #eee;
            transition: opacity 0.3s ease;
        }
        .sidebar-name {
            font-weight: 600;
            margin-top: 8px;
            color: white;
        }

        .sidebar-role {
            font-size: 13px;
            color: #cbd5f5;
        }
    </style>
</head>

<body>

    <div class="admin-wrapper">

        @inject WebQLThiTracNghiem.Data.ApplicationDbContext _context

        <!-- SIDEBAR -->
        <div class="sidebar" id="sidebar">

            <!-- USER BOX -->
            <div class="text-center mb-4">
                @{
                    var maNguoiDung = Context.Session.GetInt32("MaNguoiDung");
                    var avatar = Context.Session.GetString("Avatar");

                    if (string.IsNullOrEmpty(avatar) && maNguoiDung != null)
                    {
                        avatar = _context.HoSoCaNhan
                        .Where(x => x.MaNguoiDung == maNguoiDung)
                        .Select(x => x.AnhDaiDien) 
                        .FirstOrDefault();
                    }

                    string avatarPath = string.IsNullOrEmpty(avatar)
                    ? "/images/avatar-default.png"
                    : (avatar.StartsWith("/") ? avatar : Url.Content("~/Avatar/" + avatar));
                }

                <img src="@avatarPath"
                     class="sidebar-avatar"
                     style="opacity:0"
                     onload="this.style.opacity=1"
                     onerror="this.onerror=null; this.src='/images/avatar-default.png'; this.style.opacity=1;" />

                <div class="sidebar-name">
                    @(Context.Session.GetString("TenNguoiDung") ?? "Admin")
                </div>

                <div class="sidebar-role">
                    Quản trị viên
                </div>
            </div>

            <a asp-controller="Admin" asp-action="BangDieuKhien" class="menu-item">
                <i class="fas fa-chart-line"></i>
                <span>Tổng quan</span>
            </a>

            <div class="menu-dropdown">
                <div class="menu-item" onclick="toggleMenu(this)">
                    <i class="fas fa-users"></i>
                    <span>Quản lý người dùng</span>
                    <span class="arrow">▼</span>
                </div>

                <div class="submenu">
                    <a asp-controller="Admin" asp-action="DanhSachGiaoVien" class="menu-item">
                        <i class="fas fa-chalkboard-teacher"></i> Quản lý giáo viên
                    </a>

                    <a asp-controller="Admin" asp-action="DanhSachHocSinh" class="menu-item">
                        <i class="fas fa-user-graduate"></i> Quản lý học sinh
                    </a>

                    <a asp-controller="Admin" asp-action="NguoiDung" class="menu-item">
                        <i class="fas fa-user-cog"></i> Quản lý tài khoản
                    </a>
                </div>
            </div>

            <a asp-controller="Admin" asp-action="Lop" class="menu-item">
                <i class="fas fa-school"></i>
                <span>Quản lý lớp</span>
            </a>

            <a asp-controller="Admin" asp-action="MonHoc" class="menu-item">
                <i class="fas fa-book"></i>
                <span>Quản lý môn học</span>
            </a>

            <a asp-controller="Admin" asp-action="ChuyenDe" class="menu-item">
                <i class="fas fa-layer-group"></i>
                <span>Quản lý chuyên đề</span>
            </a>

            <a asp-controller="Admin" asp-action="PhanCongGiangDay" class="menu-item">
                <i class="fas fa-tasks"></i>
                <span>Phân công giảng dạy</span>
            </a>

            <a asp-controller="Admin" asp-action="DanhSachDotThi" class="menu-item">
                <i class="fas fa-calendar-alt"></i>
                <span>Quản lý kỳ thi</span>
            </a>

            <a asp-controller="Admin" asp-action="ThongKeTong" class="menu-item">
                <i class="fas fa-chart-pie"></i>
                <span>Thống kê</span>
            </a>


        </div> 
        <!-- CONTENT -->
        <div class="content">
            <div class="topbar d-flex justify-content-between align-items-center">

                <h5>@ViewData["Title"]</h5>

                <div class="d-flex gap-2">
                    <a asp-controller="Home" asp-action="TrangChu"
                       class="btn btn-outline-primary btn-sm">
                        Trang chủ
                    </a>

                    <a asp-controller="Auth" asp-action="DangXuat"
                       class="btn btn-danger btn-sm"
                       onclick="return confirm('Bạn có chắc muốn đăng xuất không?')">
                        Đăng xuất
                    </a>
                </div>

            </div>

            <div class="main">
                @RenderBody()
            </div>
        </div>

    </div>

    <script>
        setTimeout(function () {
            var toast = document.getElementById("loginSuccessToast");
            if (toast) {
                toast.style.transition = "opacity 0.5s ease";
                toast.style.opacity = "0";
                setTimeout(function () {
                    toast.remove();
                }, 500);
            }
        }, 2500);
    </script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleUserMenu() {
            var menu = document.getElementById("user-submenu");

            if (menu.style.display === "none") {
                menu.style.display = "block";
            } else {
                menu.style.display = "none";
            }
        }
    </script>
    @RenderSection("Scripts", required: false)
</body>

<style>


.sidebar {
    width: 250px;
    transition: 0.3s;
}

.sidebar.collapsed {
    width: 80px;
}

.sidebar.collapsed span {
    display: none;
}

.sidebar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.toggle-btn {
    border: none;
    background: transparent;
    color: white;
    font-size: 20px;
    cursor: pointer;
}

.menu-item {
    display: flex !important;
    align-items: center;
    gap: 10px;
    padding: 10px;
    border-radius: 8px;
    transition: 0.2s;
}

.menu-item:hover {
    background: rgba(255,255,255,0.2);
}

.menu-item.active {
    background: #3b82f6;
}

.submenu {
    display: none;
    padding-left: 15px;
}

.menu-dropdown.active .submenu {
    display: block;
}

.arrow {
    margin-left: auto;
}

.content {
    margin-left: 250px;
    transition: 0.3s;
}

.sidebar.collapsed + .content {
    margin-left: 80px;
}

    .submenu a.active {
        background: #3b82f6;
        color: white;
    }
</style>
<script>
    function toggleSidebar() {
        document.getElementById("sidebar").classList.toggle("collapsed");
    }

    function toggleMenu(el) {
        el.parentElement.classList.toggle("active");
    }

    document.addEventListener("DOMContentLoaded", function () {

        const links = document.querySelectorAll(".sidebar a");
        const url = window.location.pathname.toLowerCase();

        links.forEach(link => {
            const href = link.getAttribute("href");

            if (href && url.includes(href.toLowerCase())) {
                link.classList.add("active");

                const parent = link.closest(".menu-dropdown");
                if (parent) parent.classList.add("active");
            }
        });

    });
</script>

</html>