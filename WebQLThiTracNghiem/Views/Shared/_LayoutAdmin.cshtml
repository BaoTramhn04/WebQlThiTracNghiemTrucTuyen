<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" />

    <style>
        .user-info-box {
            text-align: right;
            line-height: 1.4;
        }

            .user-info-box .welcome-text {
                font-weight: 600;
                color: #1f2937;
            }

            .user-info-box .subject-text {
                font-size: 13px;
                color: #6b7280;
            }

        .login-success-toast {
            background: #d1fae5;
            color: #065f46;
            border: 1px solid #a7f3d0;
            padding: 12px 16px;
            border-radius: 10px;
            margin-bottom: 16px;
            font-weight: 500;
            animation: fadeIn 0.4s ease;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-8px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>

<body>

    <div class="admin-wrapper">

        <!-- SIDEBAR -->
        <div class="sidebar">

            <div class="sidebar-title">
                Quản trị hệ thống
            </div>

            <a asp-controller="Admin" asp-action="BangDieuKhien">
                Dashboard
            </a>

            <a asp-controller="Admin" asp-action="DanhSachGiaoVien">
                Quản lý Giáo viên
            </a>

            <a asp-controller="Admin" asp-action="DanhSachHocSinh">
                Quản lý Học sinh
            </a>

            <a asp-controller="Admin" asp-action="PhanCongGiangDay">
                Phân công giảng dạy
            </a>

            <a asp-controller="Auth" asp-action="DangXuat">
                Đăng xuất
            </a>

        </div>

        <!-- CONTENT -->
        <div class="content">

            <div class="topbar">

                <h5>@ViewData["Title"]</h5>

                <div class="user-info-box">
                    <div class="welcome-text">
                        Xin chào, @(Context.Session.GetString("TenNguoiDung") ?? "Admin")
                    </div>
                   
                </div>

            </div>

            <div class="main">

                @if (TempData["LoginSuccess"] != null)
                {
                    <div class="login-success-toast" id="loginSuccessToast">
                        @TempData["LoginSuccess"]
                    </div>
                }

                @RenderBody()

            </div>

        </div>

    </div>

    <script>
        setTimeout(function () {
            var toast = document.getElementById("loginSuccessToast");
            if (toast) {
                toast.style.transition = "opacity 0.5s ease";
                toast.style.opacity = "0";
                setTimeout(function () {
                    toast.remove();
                }, 500);
            }
        }, 2500);
    </script>

</body>
</html>